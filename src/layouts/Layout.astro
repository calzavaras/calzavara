---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  ogImageType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  schema?: string;
  preloadImage?: string;
  preloadImageType?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
}

const jsVersion = process.env.npm_package_version ?? '1';

const {
  title,
  description,
  canonical,
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  ogTitle,
  ogDescription,
  ogType = 'website',
  ogImage = 'https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.webp',
  ogImageAlt = 'Marco Calzavara, Gründer von Nigredo in St. Gallen',
  ogImageWidth = '768',
  ogImageHeight = '1024',
  ogImageType,
  twitterTitle,
  twitterDescription,
  schema,
  preloadImage,
  preloadImageType,
  preloadImageSrcset,
  preloadImageSizes,
} = Astro.props;

function inferImageType(image: string | undefined): string | undefined {
  const path = image?.split('?')[0]?.toLowerCase();
  if (!path) return undefined;
  if (path.endsWith('.jpg') || path.endsWith('.jpeg')) return 'image/jpeg';
  if (path.endsWith('.png')) return 'image/png';
  if (path.endsWith('.webp')) return 'image/webp';
  if (path.endsWith('.avif')) return 'image/avif';
  return undefined;
}

const resolvedOgImageType = ogImageType ?? inferImageType(ogImage);
const canonicalUrl = canonical === 'https://www.nigredo.ch'
  ? 'https://www.nigredo.ch/'
  : (canonical.endsWith('/') ? canonical : `${canonical}/`);

// Globales Entitäts- und Navigationsschema für konsistente Seitengraphen.
const siteIdentitySchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://www.nigredo.ch/#website",
      "name": "Nigredo",
      "url": "https://www.nigredo.ch/",
      "inLanguage": "de-CH",
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://www.nigredo.ch/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService", "Organization"],
      "@id": "https://www.nigredo.ch/#organization",
      "name": "Nigredo | Marco Calzavara",
      "url": "https://www.nigredo.ch/",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://www.nigredo.ch/#logo",
        "url": "https://www.nigredo.ch/assets/nigredo-logo.png",
        "contentUrl": "https://www.nigredo.ch/assets/nigredo-logo.png",
        "width": 831,
        "height": 265,
        "caption": "Nigredo Logo"
      },
      "image": { "@id": "https://www.nigredo.ch/#logo" },
      "description": "Websites, KI-Lösungen und Softwareentwicklung aus St. Gallen. Marco Calzavara entwickelt digitale Produkte mit Substanz – persönlich, zum Fixpreis, ohne Baukasten.",
      "founder": { "@id": "https://www.nigredo.ch/#person" },
      "foundingDate": "2025",
      "knowsAbout": ["Webdesign", "Softwareentwicklung", "KI-Lösungen", "Branding", "User Experience Design", "Automatisierung"],
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": 1 },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Wildeggstrasse 37",
        "addressLocality": "St. Gallen",
        "postalCode": "9000",
        "addressRegion": "SG",
        "addressCountry": "CH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "47.4245",
        "longitude": "9.3767"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "calzavara3830@gmail.com",
        "areaServed": "CH",
        "availableLanguage": ["German", "English"]
      },
      "priceRange": "$$",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Digitale Dienstleistungen",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Website Erstellung und Webdesign" }
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "KI-Lösungen und Automatisierung" }
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Softwareentwicklung und digitale Tools" }
          }
        ]
      },
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.nigredo.ch/#person",
      "name": "Marco Calzavara",
      "givenName": "Marco",
      "familyName": "Calzavara",
      "jobTitle": "Gründer & Full-Stack Developer",
      "url": "https://www.nigredo.ch/ueber-uns/",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.webp",
        "contentUrl": "https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.webp",
        "width": 1254,
        "height": 1254
      },
      "worksFor": { "@id": "https://www.nigredo.ch/#organization" },
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ]
    },
    {
      "@type": "SiteNavigationElement",
      "position": 1,
      "name": "Lösungen",
      "description": "Texte, Bilder, Logos, Software, Webseiten – KI-Lösungen aus einer Hand",
      "url": "https://www.nigredo.ch/loesungen/"
    },
    {
      "@type": "SiteNavigationElement",
      "position": 2,
      "name": "Referenzen",
      "description": "Echte Projekte: KI Voice Agent, Wissensdatenbanken, Design-Tools, Dashboards",
      "url": "https://www.nigredo.ch/referenzen/"
    },
    {
      "@type": "SiteNavigationElement",
      "position": 3,
      "name": "Über mich",
      "description": "Marco Calzavara – Gründer und Macher von Nigredo, St. Gallen",
      "url": "https://www.nigredo.ch/ueber-uns/"
    },
    {
      "@type": "SiteNavigationElement",
      "position": 4,
      "name": "Kontakt",
      "description": "Direkter Kontakt zu Marco Calzavara – Projektanfragen und Ideen",
      "url": "https://www.nigredo.ch/kontakt/"
    }
  ]
});
---

<!DOCTYPE html>
<html lang="de-CH">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <link rel="preconnect" href="https://cloud.umami.is" crossorigin>
  <link rel="dns-prefetch" href="https://cloud.umami.is">

  {preloadImage && (
    <link rel="preload" as="image" href={preloadImage} type={preloadImageType || undefined} imagesrcset={preloadImageSrcset || undefined} imagesizes={preloadImageSizes || undefined} />
  )}
  <meta name="format-detection" content="telephone=no">
  <meta name="theme-color" content="#050505">
  <meta name="color-scheme" content="dark">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="msapplication-TileColor" content="#050505">
  <meta name="msapplication-TileImage" content="/mstile-150x150.png">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Nigredo">
  <meta name="publisher" content="Nigredo">
  <meta name="robots" content={robots}>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt – Nigredo für KI-Bots">
  <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs-full.txt – Vollständige Inhalte für KI-Systeme">

  <!-- Lokales SEO: St. Gallen, Schweiz -->
  <meta name="geo.region" content="CH-SG">
  <meta name="geo.placename" content="St. Gallen, Schweiz">
  <meta name="geo.position" content="47.4245;9.3767">
  <meta name="ICBM" content="47.4245, 9.3767">

  <meta property="og:title" content={ogTitle || title}>
  <meta property="og:description" content={ogDescription || description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:locale" content="de_CH">
  <meta property="og:site_name" content="Nigredo">
  {ogImage && <meta property="og:image" content={ogImage}>}
  {ogImage && <meta property="og:image:secure_url" content={ogImage}>}
  {ogImage && <meta property="og:image:alt" content={ogImageAlt}>}
  {ogImage && <meta property="og:image:width" content={ogImageWidth}>}
  {ogImage && <meta property="og:image:height" content={ogImageHeight}>}
  {ogImage && resolvedOgImageType && <meta property="og:image:type" content={resolvedOgImageType}>}

  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'}>
  <meta name="twitter:title" content={twitterTitle || ogTitle || title}>
  <meta name="twitter:description" content={twitterDescription || ogDescription || description}>
  {ogImage && <meta name="twitter:image" content={ogImage}>}
  {ogImage && <meta name="twitter:image:alt" content={ogImageAlt}>}

  <meta name="umami-src" content="https://cloud.umami.is/script.js">
  <meta name="umami-website-id" content="78dc26c9-7537-4816-a7e1-9acc31bf1402">

  <!-- Hreflang: Sprache deklarieren -->
  <link rel="alternate" hreflang="de-CH" href={canonicalUrl}>
  <link rel="alternate" hreflang="x-default" href={canonicalUrl}>

  <!-- Globales Entitäts- und Navigationsschema -->
  <script type="application/ld+json" set:html={siteIdentitySchema} />
  {schema && <script type="application/ld+json" set:html={schema} />}
</head>
<body>

  <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>

  <Header />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <script src={`/main.min.js?v=${jsVersion}`} defer></script>

  <ContactModal />
</body>
</html>
