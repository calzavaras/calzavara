---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Start' },
  { href: '/digitale-loesungen/', label: 'Lösungen' },
  { href: '/referenzen/', label: 'Referenzen' },
  { href: '/marco-calzavara/', label: 'Über mich' },
];

function isActive(href: string): boolean {
  const normalizedPath = pathname === '/' ? '/' : pathname.replace(/\/?$/, '/');
  if (href === '/') return normalizedPath === '/';
  return normalizedPath === href || normalizedPath.startsWith(href);
}
---

<header class="floating-header">
  <div class="nav-container">
    <nav aria-label="Hauptnavigation">
      <a href="/" class="logo" aria-label="Nigredo Startseite">
        <picture class="logo-picture logo-picture--blink" data-logo-blink>
          <source srcset="/assets/nigredo-logo-header.webp" type="image/webp">
          <img src="/assets/nigredo-logo-header.png" alt="Nigredo - Websites, KI-Lösungen und Software aus St. Gallen" class="logo-img" width="448" height="143" loading="eager" decoding="async" fetchpriority="high">
          <svg class="logo-blink-overlay" viewBox="0 0 448 143" aria-hidden="true" focusable="false">
            <rect x="108" y="57" width="15" height="9" rx="4" fill="#0f0f11" fill-opacity="0.88"></rect>
            <rect x="135" y="57" width="15" height="9" rx="4" fill="#0f0f11" fill-opacity="0.88"></rect>
            <rect x="109" y="60" width="13" height="3" rx="1.5" fill="currentColor"></rect>
            <rect x="136" y="60" width="13" height="3" rx="1.5" fill="currentColor"></rect>
          </svg>
        </picture>
      </a>
      <div class="nav-links" id="primary-navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[{ active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="header-actions">
        <a href="/kontakt/" class="btn btn-primary header-cta">Kontakt</a>
        <button class="menu-toggle" aria-label="Menü öffnen" aria-controls="primary-navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>
</header>
