---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Start' },
  { href: '/loesungen', label: 'Lösungen' },
  { href: '/referenzen', label: 'Referenzen' },
  { href: '/ueber-uns', label: 'Über mich' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header class="floating-header">
  <div class="nav-container">
    <nav aria-label="Hauptnavigation">
      <a href="/" class="logo" aria-label="Nigredo Startseite">
        <picture class="logo-picture">
          <source srcset="/assets/nigredo-logo-header.webp" type="image/webp">
          <img src="/assets/nigredo-logo-header.png" alt="Nigredo - Websites, KI-Lösungen und Software aus St. Gallen" class="logo-img" width="448" height="143" loading="eager" decoding="async" fetchpriority="high">
        </picture>
      </a>
      <div class="nav-links" id="primary-navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[{ active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <a href="/kontakt" class:list={['mobile-cta', { active: isActive('/kontakt') }]}>Kontakt</a>
      </div>
      <div class="header-actions">
        <a href="/kontakt" class="btn btn-primary header-cta">Kontakt</a>
        <button class="menu-toggle" aria-label="Menü öffnen" aria-controls="primary-navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>
</header>
