---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://calzavara.ch/referenzen#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://calzavara.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://calzavara.ch/referenzen" }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": "https://calzavara.ch/referenzen#webpage",
      "url": "https://calzavara.ch/referenzen",
      "name": "Referenzprojekte – KI & Software für Schweizer KMU | Calzavara",
      "description": "Echte Projekte: KI Voice Agent für IV-Stellen, lokales Excel-Dashboard für Kantonsverwaltung. Massgeschneiderte digitale Lösungen von Calzavara, St. Gallen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-21",
      "isPartOf": { "@id": "https://calzavara.ch/#website" },
      "breadcrumb": { "@id": "https://calzavara.ch/referenzen#breadcrumb" },
      "isAccessibleForFree": true,
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "url": "https://calzavara.ch/referenzen/ki-voice-agent", "name": "KI Voice Agent für IV-Stellen" },
          { "@type": "ListItem", "position": 2, "url": "https://calzavara.ch/referenzen/dashboard-kantonsverwaltung", "name": "Dashboard für Kantonsverwaltung" }
        ]
      }
    }
  ]
});
---

<Layout
  title="Referenzprojekte – KI & Software für Schweizer KMU | Calzavara"
  description="Echte Projekte: KI Voice Agent für IV-Stellen, lokales Excel-Dashboard für Kantonsverwaltung. Massgeschneiderte digitale Lösungen von Calzavara, St. Gallen."
  keywords="Referenzen Calzavara, KI Voice Agent Schweiz, Excel Dashboard Kantonsverwaltung, digitale Lösungen Schweiz, Softwareentwicklung Referenzen, KI-Projekte St. Gallen, Website Referenzen KMU"
  canonical="https://calzavara.ch/referenzen"
  ogTitle="Gebaut. Nicht gepitcht. | Calzavara"
  ogDescription="Keine Demos, keine Konzeptpapiere. Projekte, die raus sind und arbeiten. KI Voice Agent, Excel-Dashboard und mehr."
  ogImageAlt="Calzavara Referenzen – Echte Projekte, keine Demos"
  twitterTitle="Gebaut. Nicht gepitcht. | Calzavara"
  twitterDescription="Keine Demos, keine Konzeptpapiere. Projekte, die raus sind und arbeiten."
  schema={schema}
>
  <section class="section pt-sub">
    <div class="hero-glow" style="top: -200px; background: radial-gradient(circle, rgba(255,77,128,0.12) 0%, rgba(166,77,255,0.08) 40%, transparent 70%); opacity: 0.6;"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen' }
      ]} />

      <div class="fade-up" style="text-align: left; max-width: 850px; margin-bottom: 64px;">
        <span class="badge badge--purple">GEBAUT. NICHT GEPITCHT.</span>

        <h1 style="margin-top: 15px;">
          Echte Aufgaben.<br>
          <span class="gradient-text">Echte Ergebnisse.</span>
        </h1>
        <p>
          Jedes Projekt hier hatte einen echten Auftraggeber und ein echtes Problem. Kein Showpiece, kein Vorführprojekt. Einfach Arbeit, die gemacht werden musste.
        </p>
      </div>

      <div id="refs-grid" class="refs-grid" aria-live="polite"></div>

      <div class="refs-nav" id="refs-nav">
        <button class="refs-nav-btn" id="refs-prev" aria-label="Vorherige Projekte">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        </button>
        <span class="refs-nav-count" id="refs-nav-count"></span>
        <button class="refs-nav-btn" id="refs-next" aria-label="Nächste Projekte">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </button>
      </div>

      <div class="refs-cta fade-up">
        <span class="cta-label">Der nächste Schritt</span>
        <h2>Nächstes Projekt?<br><span class="gradient-text">Erzähl mir davon.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen</a>
          <a href="/ueber-uns" class="btn btn-ghost">Über mich</a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  /* Main Grid */
  .refs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 96px;
  }

  /* Card */
  .ref-main-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.015);
    background-clip: padding-box;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease;
  }
  .ref-main-card::before {
    content: "";
    position: absolute; inset: 0; border-radius: inherit; padding: 1px;
    background: conic-gradient(from var(--border-angle), #FFC700, #FF4D80, #A64DFF, #00D2FF, #FFC700);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    opacity: 0; transition: opacity 0.4s ease;
    pointer-events: none; z-index: 2;
  }
  @media (hover: hover) {
    .ref-main-card:hover {
      transform: translateY(-5px);
      border-color: transparent;
      box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }
    .ref-main-card:hover::before {
      opacity: 1;
      animation: borderRotate 4s linear infinite;
    }
    .ref-main-card:hover .ref-main-card-img img {
      transform: scale(1.04);
    }
    .ref-main-card:hover .ref-main-link {
      gap: 8px;
    }
    .ref-main-card:hover .ref-main-link--ki { color: #A64DFF; }
    .ref-main-card:hover .ref-main-link:not(.ref-main-link--ki) { color: #00D2FF; }
  }

  /* Image Area */
  .ref-main-card-img {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .ref-main-card-img--purple {
    background:
      radial-gradient(ellipse at 25% 35%, rgba(166,77,255,0.65) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 65%, rgba(255,77,128,0.35) 0%, transparent 50%),
      #0c0814;
  }
  .ref-main-card-img--cyan {
    background:
      radial-gradient(ellipse at 25% 35%, rgba(0,210,255,0.55) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 65%, rgba(166,77,255,0.28) 0%, transparent 50%),
      #030d14;
  }
  .ref-main-card-img img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .ref-main-badge {
    position: absolute;
    top: 16px; left: 16px;
    z-index: 1;
  }

  /* Card Body */
  .ref-main-card-body {
    padding: 28px 30px 30px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ref-main-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .ref-main-card-year {
    font-size: 0.72rem;
    font-weight: 400;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 3px;
  }
  .ref-main-card-title {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin: 0 0 14px;
    color: #fff;
  }
  .ref-main-card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.68;
    margin: 0;
    max-width: none;
    flex: 1;
  }

  /* Footer */
  .ref-main-card-footer {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .ref-main-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
    transition: gap 0.25s ease, color 0.25s ease;
  }

  /* Navigation Pfeile */
  .refs-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin: 32px 0 80px;
  }
  .refs-nav-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    background: transparent;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .refs-nav-btn:hover:not(:disabled) {
    border-color: rgba(166,77,255,0.5);
    color: #fff;
    background: rgba(166,77,255,0.08);
  }
  .refs-nav-btn:disabled {
    opacity: 0.2;
    cursor: default;
  }
  .refs-nav-count {
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.1em;
    min-width: 40px;
    text-align: center;
  }

  /* CTA — konsistent mit Startseite und Lösungen */
  .refs-cta {
    text-align: center;
    padding-top: 64px;
    border-top: 1px solid rgba(255,255,255,0.05);
    max-width: 640px;
    margin: 0 auto;
  }
  .refs-cta h2 { margin-bottom: 16px; }
  .refs-cta p {
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 36px;
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .refs-grid { grid-template-columns: 1fr; gap: 20px; }
    .ref-main-card-body { padding: 22px 22px 24px; }
    .refs-nav { margin: 24px 0 60px; }
    .refs-cta { padding-top: 48px; }
    .hero-cta-group { flex-direction: column; align-items: center; }
    .hero-cta-group .btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 480px) {
    .cta-label { font-size: 0.6rem; }
  }
</style>

<script>
  const REFS = [
    {
      href: '/referenzen/ki-voice-agent',
      imgSrc: '/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.svg',
      imgAlt: 'KI Voice Agent für IV-Stellen – AHV Hilfsmittel Sprachassistent von Calzavara',
      imgCls: 'ref-main-card-img--purple',
      badge: { text: 'KI-Agent', cls: 'accent-purple' },
      linkCls: 'ref-main-link--ki',
      year: 'Feb 2026',
      title: 'KI Voice Agent für IV-Stellen',
      desc: 'Kein Mensch kann rund um die Uhr ans Telefon, eine KI schon. Vier Sprachen, null Wartezeit und ein Wissensstand, der nicht vom letzten Urlaub des Sachbearbeiters abhängt.',
      ariaLabel: 'KI Voice Agent für IV-Stellen – Details ansehen'
    },
    {
      href: '/referenzen/dashboard-kantonsverwaltung',
      imgSrc: '/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.svg',
      imgAlt: 'Dashboard für Kantonsverwaltung – Excel KPI-Auswertung im Browser ohne Cloud',
      imgCls: 'ref-main-card-img--cyan',
      badge: { text: 'App', cls: 'accent-cyan' },
      linkCls: '',
      year: 'Jun 2025',
      title: 'Dashboard für Kantonsverwaltung',
      desc: 'Sensible Daten, die bleiben wo sie hingehören: auf dem eigenen Rechner. Ein Klick bis zum fertigen Bericht, kein Cloud-Upload, kein IT-Ticket, kein Nerv.',
      ariaLabel: 'Dashboard für Kantonsverwaltung – Details ansehen'
    }
    // Weitere Referenzen hier einfach anhängen
  ];

  const ARROW_SVG = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function cardHTML(ref) {
    return `
      <a href="${ref.href}" class="ref-main-card" aria-label="${ref.ariaLabel}">
        <div class="ref-main-card-img ${ref.imgCls}">
          <img src="${ref.imgSrc}" alt="${ref.imgAlt}" width="800" height="450" loading="lazy">
          <span class="tech-badge ${ref.badge.cls} ref-main-badge">${ref.badge.text}</span>
        </div>
        <div class="ref-main-card-body">
          <div class="ref-main-card-header">
            <h2 class="ref-main-card-title">${ref.title}</h2>
            <span class="ref-main-card-year">${ref.year}</span>
          </div>
          <p class="ref-main-card-desc">${ref.desc}</p>
          <div class="ref-main-card-footer">
            <span class="ref-main-link ${ref.linkCls}">Details ${ARROW_SVG}</span>
          </div>
        </div>
      </a>`;
  }

  const PER_PAGE = 2;
  const shuffled = shuffle(REFS);
  const totalPages = Math.ceil(shuffled.length / PER_PAGE);
  let page = 0;

  const grid    = document.getElementById('refs-grid');
  const nav     = document.getElementById('refs-nav');
  const prevBtn = document.getElementById('refs-prev');
  const nextBtn = document.getElementById('refs-next');
  const counter = document.getElementById('refs-nav-count');

  // Nav nur zeigen wenn mehr als 1 Seite
  nav.style.display = totalPages > 1 ? 'flex' : 'none';

  function render() {
    const visible = shuffled.slice(page * PER_PAGE, (page + 1) * PER_PAGE);
    grid.innerHTML = visible.map(cardHTML).join('');
    prevBtn.disabled = page === 0;
    nextBtn.disabled = page >= totalPages - 1;
    if (totalPages > 1) counter.textContent = `${page + 1} / ${totalPages}`;
  }

  prevBtn.addEventListener('click', () => { if (page > 0) { page--; render(); } });
  nextBtn.addEventListener('click', () => { if (page < totalPages - 1) { page++; render(); } });

  render();
</script>
