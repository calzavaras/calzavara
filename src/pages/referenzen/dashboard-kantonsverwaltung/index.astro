---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://laborium.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://laborium.ch/referenzen" },
        { "@type": "ListItem", "position": 3, "name": "Dashboard für Kantonsverwaltung", "item": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung" }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung#software",
      "name": "Dashboard für Kantonsverwaltung",
      "url": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung",
      "description": "Lokales Excel-Analyse-Dashboard für eine Schweizer Kantonsverwaltung. Drag & Drop Import, KPIs, Diagramme, Anonymisierung und PDF-Export. 100% lokal – keine Daten verlassen den Rechner.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "de",
      "dateCreated": "2025-04-01",
      "datePublished": "2026-02-28",
      "featureList": [
        "Drag & Drop Excel-Import",
        "KPI-Auswertung",
        "Interaktive Diagramme",
        "Anonymisierung per Knopfdruck",
        "PDF-Export",
        "100% lokal im Browser"
      ],
      "screenshot": [
        {
          "@type": "ImageObject",
          "url": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.png",
          "caption": "Dashboard für Kantonsverwaltung – KPI-Übersicht mit Diagrammen und Auswertungen"
        }
      ],
      "creator": { "@id": "https://laborium.ch/#organization" }
    },
    {
      "@type": "WebPage",
      "@id": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung#webpage",
      "name": "Dashboard für Kantonsverwaltung | Calzavara Referenzen",
      "url": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung",
      "isPartOf": { "@id": "https://laborium.ch/#website" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-21",
      "about": { "@id": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung#software" },
      "breadcrumb": { "@id": "https://laborium.ch/referenzen/dashboard-kantonsverwaltung#breadcrumb" },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".case-hero-lead", ".case-feature-body h3"]
      }
    }
  ]
});
---

<Layout
  title="Dashboard für Kantonsverwaltung | Calzavara Referenzen"
  description="Lokales Excel-Analyse-Dashboard für eine Schweizer Kantonsverwaltung: Drag & Drop Import, KPIs, Diagramme, Anonymisierung, PDF-Export. Sensible Personaldaten bleiben 100% lokal im Browser. Von Calzavara, St. Gallen."
  keywords="Excel Dashboard Browser, lokale Datenanalyse, Personaldaten Analyse Tool, Anonymisierung Excel, KPI Dashboard Kantonsverwaltung, datenschutzkonformes Dashboard Schweiz, Offline Excel Auswertung"
  canonical="https://laborium.ch/referenzen/dashboard-kantonsverwaltung"
  ogTitle="Dashboard für Kantonsverwaltung"
  ogDescription="Excel-Analyse ohne Cloud: KPIs, Diagramme, Anonymisierung und PDF-Export – alles lokal im Browser. Massgeschneidert von Calzavara."
  ogImage="https://laborium.ch/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.png"
  ogImageAlt="Lokales Excel-Dashboard für Kantonsverwaltung – KPI-Auswertung ohne Cloud von Calzavara"
  ogImageWidth="1534"
  ogImageHeight="860"
  twitterTitle="Dashboard für Kantonsverwaltung"
  twitterDescription="Excel-Analyse ohne Cloud: KPIs, Diagramme, Anonymisierung – alles lokal im Browser."
  schema={schema}
>
  <section class="section pt-sub">
    <div class="container">
      <div class="hero-glow" style="top: -200px; background: radial-gradient(circle, rgba(0,210,255,0.15) 0%, transparent 70%); opacity: 0.5;"></div>

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen', href: '/referenzen' },
        { label: 'Dashboard' }
      ]} />

      <a href="/referenzen" class="case-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Alle Referenzen
      </a>

      <!-- Hero: Split Layout -->
      <div class="case-hero fade-up">
        <div class="case-hero-content">
          <span class="tech-badge accent-cyan case-hero-badge">App</span>
          <h1>Dashboard für <span class="gradient-text">Kantonsverwaltung</span></h1>
          <p class="case-hero-lead">
            Excel rein, Auswertung raus. Kein Server, keine Cloud, keine IT-Abteilung, die zuerst nicken muss. Sensible Personaldaten bleiben da, wo sie hingehören: auf dem eigenen Rechner.
          </p>
          <!-- Live-Button: URL einsetzen und Kommentar entfernen
          <a href="https://..." target="_blank" rel="noopener" class="case-live-btn">
            Live ansehen
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
          -->
        </div>

        <div class="case-hero-visual">
          <div class="case-hero-canvas case-hero-canvas--cyan">
            <button
              type="button"
              class="case-hero-float lightbox-trigger"
              data-gallery='["/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.png"]'
              data-gallery-index="0"
              aria-label="Screenshot vergrössern"
            >
              <img
                src="/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.png"
                alt="Dashboard Kantonsverwaltung – Allgemeine Auswertungen"
                width="1534" height="860"
              >
            </button>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="case-stats fade-up delay-100" style="--stats-cols: 4;">
        <div class="case-stat">
          <strong>100%</strong>
          <span>Lokal</span>
        </div>
        <div class="case-stat">
          <strong>0</strong>
          <span>Cloud-Uploads</span>
        </div>
        <div class="case-stat">
          <strong>1 Klick</strong>
          <span>Anonymisierung</span>
        </div>
        <div class="case-stat">
          <strong>PDF</strong>
          <span>Bericht-Export</span>
        </div>
      </div>

      <!-- Lösung -->
      <div class="case-section fade-up delay-100">
        <div class="case-section-hd">
          <span class="case-eyebrow">Was wurde gebaut</span>
          <h2 class="case-section-title">Die Lösung</h2>
        </div>
        <div class="case-features">
          <div class="case-feature">
            <div class="case-feature-body">
              <h3>Drag & Drop Import</h3>
              <p>Datei reinziehen, fertig. Keine Installation, kein Upload, keine Genehmigung von oben. Die Verarbeitung passiert still und leise direkt im Browser.</p>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <h3>Anonymisierung auf Knopfdruck</h3>
              <p>KPIs und Diagramme gehen in die Präsentation, die Echtnamen bleiben im Büro. Datenschutz als Feature, nicht als Afterthought.</p>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <h3>PDF-Export</h3>
              <p>Ein Klick, ein druckfertiger Report. Diagramme, Kennzahlen, aufgeräumtes Layout und das Gefühl, alles im Griff zu haben.</p>
            </div>
          </div>
        </div>
      </div>

      <span class="case-date fade-up">Abgeschlossen: Juni 2025</span>

      <!-- Nächstes Projekt -->
      <div class="fade-up case-footer">
        <span class="case-next-label">Weiteres Projekt</span>
        <a href="/referenzen/ki-voice-agent" class="case-next-card">
          <div class="case-next-card-img case-next-card-img--purple case-next-card-img--portrait">
            <img src="/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.png" alt="KI Voice Agent für IV-Stellen – AHV Sprachassistent von Calzavara" loading="lazy" />
          </div>
          <div class="case-next-card-body">
            <span class="tech-badge accent-purple">KI-Agent</span>
            <p class="case-next-card-title">KI Voice Agent für IV-Stellen</p>
            <span class="case-next-card-arrow case-next-card-arrow--ki">
              Details ansehen
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      </div>

      <!-- CTA -->
      <div class="fade-up case-page-cta">
        <span class="case-cta-label">Der nächste Schritt</span>
        <h2>Etwas, das einfach<br><span class="gradient-text">auf deinem Rechner läuft?</span></h2>
        <p>Kein Server, keine Abhängigkeiten, keine überraschenden Rechnungen am Monatsende. Erzähl mir, was du brauchst.</p>
        <div class="hero-cta-group" style="justify-content: center;">
          <a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen</a>
          <a href="/referenzen" class="btn btn-ghost">Alle Projekte</a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  /* Feature Cards: 3-spaltig */
  .case-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .case-feature { grid-template-columns: 1fr; }
  .case-feature-body h3 { font-size: 0.95rem; }
  .case-feature-body p { font-size: 0.85rem; }

  /* Live-Button */
  .case-live-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 28px;
    padding: 10px 20px;
    border-radius: 8px;
    border: 1px solid rgba(0,210,255,0.3);
    background: rgba(0,210,255,0.06);
    color: #00D2FF;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: background 0.25s, border-color 0.25s, gap 0.25s;
  }
  .case-live-btn:hover {
    background: rgba(0,210,255,0.12);
    border-color: rgba(0,210,255,0.55);
    gap: 10px;
  }

  /* CTA — identisch mit Startseite / Lösungen */
  .case-page-cta {
    text-align: center;
    max-width: 640px;
    margin: 80px auto 0;
    padding-top: 64px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .case-page-cta h2 { margin-bottom: 16px; }
  .case-page-cta p {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 auto 36px;
    max-width: 52ch;
  }
  .case-cta-label {
    display: block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 12px;
  }

  /* Responsive: Tablet */
  @media (max-width: 900px) {
    .case-features { grid-template-columns: repeat(2, 1fr); }
  }

  /* Responsive: Mobile */
  @media (max-width: 600px) {
    .case-features { grid-template-columns: 1fr; }
    .case-live-btn { width: 100%; justify-content: center; }
    .case-page-cta { margin-top: 56px; padding-top: 44px; }
    .case-page-cta .hero-cta-group { flex-direction: column; align-items: stretch; }
    .case-page-cta .hero-cta-group .btn { justify-content: center; }
  }
</style>
