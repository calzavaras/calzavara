---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/kontakt/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": pageUrl }
      ]
    },
    {
      "@type": "ContactPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Kontakt und Projektanfrage | Nigredo St. Gallen",
      "url": pageUrl,
      "description": "Direkter Kontakt zu Marco Calzavara, Nigredo St. Gallen. Projektanfragen für Software, Webseiten, Texte, Bilder und KI-Lösungen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-05-03",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".contact-text"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/#organization" }
    }
  ]
});
---

<Layout
  title="Kontakt und Projektanfrage | Nigredo St. Gallen"
  description="Direkter Kontakt zu Marco Calzavara. Ich sortiere mit dir, was sinnvoll ist und welcher nächste Schritt wirklich weiterbringt."
  canonical={pageUrl}
  ogTitle="Erzähl mir kurz, was du vorhast."
  ogDescription="Direkter Kontakt zu Marco Calzavara. Keine Umwege, kein Ticketsystem, kein Agenturtheater."
  ogImageAlt="Nigredo Kontakt - Direkter Draht zu Marco Calzavara"
  twitterTitle="Erzähl mir kurz, was du vorhast."
  twitterDescription="Direkter Kontakt zu Marco Calzavara. Persönlich, klar und ohne Umwege."
  schema={schema}
>
  <section class="section pt-sub contact-hero" aria-labelledby="kontakt-title">
    <div class="hero-glow"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Kontakt' }
      ]} />

      <div class="kontakt-grid">

        <div class="fade-up contact-hero__content">
          <span class="badge badge--purple">PROJEKTANFRAGE</span>
          <h1 id="kontakt-title" class="contact-hero__title">
            Erzähl mir kurz,<br>
            <span class="gradient-text">was du vorhast.</span>
          </h1>
          <p class="hero-lead contact-hero__lead">
            Ob erste Idee, konkreter Auftrag oder offene Frage: Schreib mir, wo du gerade stehst. Ich sortiere mit dir, was sinnvoll ist, was es braucht und welcher nächste Schritt wirklich weiterbringt.
          </p>
          <p class="kontakt-sub">
            Wenn es passt, wird daraus ein klares Vorgehen: mit transparentem Fixpreis, gutem Tempo und einem Ergebnis, das zu dir, deinem Projekt und deinem Anspruch passt.
          </p>
          <p class="kontakt-sub">
            Für Kontakt und Projektanfrage reicht ein kurzer Einstieg. Erzähl mir kurz, was du vorhast, ob es um eine Website, lokale Sichtbarkeit, ein CMS, Inhalte oder eine KI-Lösung geht. Ich melde mich mit einer klaren Einschätzung zurück, damit du schnell siehst, was sinnvoll ist und was nicht.
          </p>
        </div>

        <div class="contact-card contact-panel fade-up delay-100">
          <div class="contact-top-stripe"></div>

          <div class="card-icon">
            <svg width="48" height="48" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" aria-hidden="true" focusable="false">
              <defs>
                <linearGradient id="mailGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#7DFF72"/>
                  <stop offset="45%" stop-color="#00E7B7"/>
                  <stop offset="100%" stop-color="#00B8FF"/>
                </linearGradient>
              </defs>
              <rect x="4" y="10" width="40" height="28" rx="4" stroke="url(#mailGrad)" stroke-width="2" fill="none"/>
              <path d="M4 15l20 14 20-14" stroke="url(#mailGrad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>

          <span class="cta-label">Direkter Kontakt</span>
          <h2>Persönlich statt Prozess.</h2>
          <p class="contact-text">Deine Anfrage landet ohne Umweg bei mir. Ich lese sie selbst und melde mich mit einer ehrlichen Einschätzung zurück. Kein Formularlabyrinth, kein Verkaufsritual. Einfach ein sinnvoller nächster Schritt.</p>

          <button id="mailBtn" class="btn btn-primary">Jetzt schreiben</button>
        </div>

      </div>

    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(92px, 9vw, 128px);
  }

  .contact-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .contact-hero .badge {
    margin-bottom: 1.15rem;
    color: #ebffef;
    border-color: rgba(125, 255, 114, 0.42);
    background:
      linear-gradient(135deg, rgba(125, 255, 114, 0.2), rgba(0, 255, 183, 0.2), rgba(0, 184, 255, 0.14));
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.03),
      0 0 0 1px rgba(125, 255, 114, 0.18),
      0 0 32px rgba(0, 255, 183, 0.14);
  }

  .kontakt-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.72fr);
    gap: clamp(44px, 6vw, 80px);
    align-items: center;
  }

  .contact-hero__content {
    max-width: 940px;
  }

  .contact-hero__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: clamp(24px, 3vw, 30px);
  }

  .contact-hero .gradient-text {
    background: linear-gradient(90deg, #7dff72 0%, #00ffb7 36%, #00b8ff 76%, #7dff72 100%);
    background-size: 260% auto;
    animation: gradientPan 46s linear infinite;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 0 18px rgba(0, 231, 183, 0.22));
  }

  .contact-hero__lead {
    max-width: 620px;
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .contact-hero .hero-glow {
    background:
      radial-gradient(circle at 18% 38%, rgba(125, 255, 114, 0.11) 0%, transparent 34%),
      radial-gradient(circle at 54% 44%, rgba(0, 255, 183, 0.12) 0%, transparent 32%),
      radial-gradient(circle at 84% 28%, rgba(0, 184, 255, 0.1) 0%, transparent 28%);
  }

  .kontakt-sub {
    max-width: 610px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.48);
    font-size: clamp(0.98rem, 1.08vw, 1.05rem);
    line-height: 1.65;
  }

  .contact-panel {
    position: relative;
    align-self: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.018)),
      #0a0a0c;
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .contact-panel::before,
  .contact-panel::after {
    display: none;
  }

  .contact-panel:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  /* Top gradient accent stripe */
  .contact-top-stripe {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #7DFF72, #00FFB7, #00B8FF);
    border-radius: 2px 2px 0 0;
  }

  .contact-panel .cta-label {
    margin-bottom: 12px;
    color: rgba(255, 255, 255, 0.42);
  }

  .contact-panel h2 {
    font-size: clamp(1.45rem, 2.4vw, 1.72rem);
    line-height: 1.14;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }

  .contact-text {
    color: rgba(255, 255, 255, 0.56);
    margin-bottom: 32px;
    font-size: 0.98rem;
    line-height: 1.68;
  }

  .contact-card .card-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.024)),
      rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 0 16px rgba(0, 255, 183, 0.16);
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  .contact-card .card-icon svg {
    width: 30px;
    height: 30px;
    filter:
      brightness(1.16)
      saturate(1.3)
      drop-shadow(0 0 8px rgba(0, 255, 183, 0.24));
    transition: filter 0.45s ease;
  }

  .contact-card:hover .card-icon {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.025)),
      rgba(255, 255, 255, 0.035);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 24px rgba(0, 255, 183, 0.18),
      0 0 48px rgba(0, 184, 255, 0.14);
  }

  .contact-card:hover .card-icon svg {
    filter:
      brightness(1.22)
      saturate(1.42)
      drop-shadow(0 0 12px rgba(0, 255, 183, 0.3))
      drop-shadow(0 0 24px rgba(0, 184, 255, 0.22));
  }

  @media (max-width: 860px) {
    .contact-hero {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 82px;
    }

    .kontakt-grid {
      grid-template-columns: 1fr;
      gap: 38px;
    }

    .contact-hero__title {
      font-size: var(--hero-title-size-tablet);
      line-height: var(--hero-title-line-height-mobile);
      letter-spacing: 0;
    }
  }

  @media (max-width: 520px) {
    .contact-hero {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 68px;
    }

    .contact-hero__title {
      font-size: var(--hero-title-size-mobile);
      line-height: var(--hero-title-line-height-mobile);
      letter-spacing: 0;
    }

    .contact-hero__lead {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .kontakt-sub {
      font-size: 0.96rem;
      line-height: 1.62;
      margin-top: 18px;
    }

    .contact-panel {
      padding: 30px 24px;
    }
  }
</style>
