---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/website-fuer-einzelunternehmen-kmu/';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://www.nigredo.ch/loesungen/" },
        { "@type": "ListItem", "position": 3, "name": "Einzelfirmen & KMU", "item": pageUrl }
      ]
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      "name": "Website für Einzelfirmen und KMU",
      "serviceType": "Webdesign für Einzelfirmen, Selbständige und KMU",
      "description": "Professionelle Websites für Einzelfirmen, Selbständige und KMU. Klar positioniert, mobil optimiert, suchmaschinenfreundlich und ohne Baukasten oder Agentur-Overhead.",
      "provider": { "@id": "https://www.nigredo.ch/#organization" },
      "areaServed": [
        { "@type": "City", "name": "St. Gallen" },
        { "@type": "AdministrativeArea", "name": "Ostschweiz" },
        { "@type": "Country", "name": "Switzerland" }
      ],
      "audience": {
        "@type": "Audience",
        "audienceType": "Einzelfirmen, Selbständige und kleine Unternehmen"
      },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "CHF",
        "availability": "https://schema.org/InStock",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "description": "Fixpreis nach Umfang"
        }
      }
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Website für Einzelfirmen & KMU | Nigredo",
      "description": "Professionelle Websites für Einzelfirmen, Selbständige und KMU. Klar positioniert, mobil optimiert und suchmaschinenfreundlich umgesetzt.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "about": { "@id": `${pageUrl}#service` },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-05",
      "dateModified": "2026-05-05",
      "isAccessibleForFree": true,
      "mainEntity": { "@id": `${pageUrl}#service` }
    }
  ]
});
---

<Layout
  title="Website für Einzelfirmen & KMU | Nigredo"
  description="Professionelle Websites für Einzelfirmen und KMU: klar positioniert, mobil optimiert und suchmaschinenfreundlich. Aus St. Gallen für die Schweiz."
  keywords="Website für Einzelfirma, Website für KMU, Webdesign für kleine Unternehmen, professionelle Webvisitenkarte, Webdesign St. Gallen"
  canonical={pageUrl}
  ogTitle="Website für Einzelfirmen & KMU | Klar, professionell, ohne Baukasten"
  ogDescription="Professionelle Websites für Einzelfirmen und KMU. Klar, schnell und suchmaschinenfreundlich."
  twitterTitle="Website für Einzelfirmen & KMU | Nigredo"
  twitterDescription="Professionelle Websites für kleine Unternehmen, Selbständige und KMU."
  schema={schema}
>
  <section class="section pt-sub seo-page seo-page--yellow" aria-labelledby="einzelfirma-title">
    <div class="hero-glow"></div>
    <div class="container seo-page__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Lösungen', href: '/loesungen/' },
        { label: 'Einzelfirmen & KMU' }
      ]} />

      <div class="seo-hero fade-up">
        <span class="badge badge--yellow">EINZELFIRMEN & KMU</span>
        <h1 id="einzelfirma-title" class="home-hero__title seo-hero__title">
          Website für Einzelfirmen<br>
          <span class="gradient-text">&amp; KMU.</span>
        </h1>
        <p class="hero-lead seo-hero__lead">
          Kleine Unternehmen brauchen keinen Baukasten. Sie brauchen eine Website, die klar zeigt, was sie tun, Vertrauen schafft und Anfragen leicht macht.
        </p>
        <div class="hero-cta-group">
          <a href="/kontakt/" class="btn btn-primary">Erzähl mir, was du brauchst</a>
          <a href="/lokal-gefunden-werden/" class="btn btn-ghost">Lokal gefunden werden</a>
        </div>
      </div>

      <div class="seo-split mt-80">
        <div class="seo-copy fade-up delay-100">
          <span class="cta-label">Warum nicht einfach Wix oder Jimdo?</span>
          <h2>Eine gute Website ist klar, schnell und glaubwürdig.</h2>
          <p>
            Baukasten-Systeme wirken am Anfang bequem. Doch oft enden sie bei starren Layouts, träger Technik und einem Auftritt, der aussieht wie viele andere.
          </p>
          <p>
            Eine kleine Website darf reduziert sein, aber sie muss exakt sitzen. Keine Spielereien, keine Hürden, keine unnötigen Unterseiten. Sondern klare Führung, schnelle Ladezeit und ein Auftritt, der deine Qualität sichtbar macht. Wenn dein Geschäft zusätzlich regional sichtbar werden soll, geht der nächste Schritt über <a href="/lokal-gefunden-werden/">lokale Sichtbarkeit für Praxen und Dienstleister</a>.
          </p>
        </div>

        <aside class="seo-note fade-up delay-150" aria-label="Kurz gesagt">
          <span class="seo-note__label">Kurz gesagt</span>
          <p>Du brauchst keine riesige Website. Du brauchst eine, die sofort verständlich ist und Vertrauen schafft.</p>
        </aside>
      </div>

      <section class="seo-section fade-up" aria-labelledby="einzelfirma-output">
        <div class="seo-section__head">
          <span class="cta-label">Was entsteht</span>
          <h2 id="einzelfirma-output">Was Besucher in den ersten Sekunden verstehen müssen.</h2>
        </div>
        <div class="seo-card-grid">
          <article class="seo-card" style="--icon-gradient: linear-gradient(135deg, #00d2ff 0%, #a64dff 100%); --icon-shadow: rgba(0, 210, 255, 0.34);">
            <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-kmu-kompass.svg'); mask-image: url('/assets/icons/icon-kmu-kompass.svg');"></div></div>
            <span class="cta-label">Positionierung</span>
            <h3>Sofort verständlich</h3>
            <p>In wenigen Sekunden ist klar, was du anbietest, für wen es gedacht ist und warum man dir vertrauen kann.</p>
          </article>
          <article class="seo-card delay-100" style="--icon-gradient: linear-gradient(135deg, #ffc700 0%, #ff4d80 100%); --icon-shadow: rgba(196, 77, 255, 0.34);">
            <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-kmu-kontaktweg.svg'); mask-image: url('/assets/icons/icon-kmu-kontaktweg.svg');"></div></div>
            <span class="cta-label">Anfrage</span>
            <h3>Kurzer Weg zum Kontakt</h3>
            <p>Telefon, Formular oder Termin: der nächste Schritt ist klar sichtbar und auf jedem Gerät leicht erreichbar.</p>
          </article>
          <article class="seo-card delay-200" style="--icon-gradient: linear-gradient(135deg, #a64dff 0%, #ff4d80 100%); --icon-shadow: rgba(255, 77, 128, 0.32);">
            <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-kmu-vertrauen.svg'); mask-image: url('/assets/icons/icon-kmu-vertrauen.svg');"></div></div>
            <span class="cta-label">Eindruck</span>
            <h3>Professionell ohne Ballast</h3>
            <p>Der Auftritt wirkt wertig, schnell und sauber statt überladen, generisch oder technisch schwerfällig.</p>
          </article>
        </div>
      </section>

      <section class="seo-section seo-band fade-up" aria-labelledby="einzelfirma-fit">
        <div>
          <span class="cta-label">Für wen</span>
          <h2 id="einzelfirma-fit">Für Selbständige, Handwerker und KMU mit klarem Angebot.</h2>
        </div>
        <p>
          Für Freiberufler, Berater, Praxen, Handwerker und kleinere Unternehmen, die ohne Agenturtheater einen klaren ersten Eindruck hinterlassen wollen. Typische Fragen zu Umfang, Preis oder CMS beantworte ich gesammelt auf der Seite <a href="/haeufige-fragen-webdesign/">Häufige Fragen zu Webdesign</a>.
        </p>
      </section>

      <section class="seo-section fade-up" aria-labelledby="einzelfirma-process">
        <div class="seo-section__head">
          <span class="cta-label">Vorgehen</span>
          <h2 id="einzelfirma-process">So läuft die Umsetzung ab.</h2>
        </div>
        <div class="seo-steps">
          <div><strong>1. Verstehen</strong><p>Wir klären, was du anbietest, wen du erreichen willst und was auf die Website gehört.</p></div>
          <div><strong class="delay-100">2. Verdichten</strong><p>Ich reduziere auf das Wesentliche: klare Struktur, klare Aussagen, klarer nächster Schritt.</p></div>
          <div><strong class="delay-200">3. Umsetzen</strong><p>Danach wird die Website sauber entwickelt, getestet und publiziert. Ohne Umwege.</p></div>
        </div>
      </section>

      <section class="section seo-final-section fade-up">
        <div class="section-cta seo-final-cta">
          <span class="cta-label">NÄCHSTER SCHRITT</span>
          <h2>Wer dich nicht findet,<br><span>kann dich nicht beauftragen.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Erzähl mir, was du brauchst</a>
            <a href="/lokal-gefunden-werden/" class="btn btn-ghost">Mehr zu lokaler Sichtbarkeit</a>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>
