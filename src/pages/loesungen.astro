---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://calzavara.ch/loesungen#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://calzavara.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://calzavara.ch/loesungen" }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://calzavara.ch/loesungen#webpage",
      "url": "https://calzavara.ch/loesungen",
      "name": "Websites, KI-Lösungen & Texte – Fixpreis | Calzavara Schweiz",
      "description": "Websites, die ihren Job kennen. KI, die nicht nervt. Texte und Bilder, denen Form fehlt. Alles aus einer Hand, Fixpreis, kein Baukastensystem. Marco Calzavara, St. Gallen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-04-07",
      "isPartOf": { "@id": "https://calzavara.ch/#website" },
      "breadcrumb": { "@id": "https://calzavara.ch/loesungen#breadcrumb" },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".accordion-content p"]
      },
      "mainEntity": { "@id": "https://calzavara.ch/loesungen#services" }
    },
    {
      "@type": "ItemList",
      "@id": "https://calzavara.ch/loesungen#services",
      "name": "Leistungen",
      "description": "Digitale Lösungen aus einer Hand – Websites, KI und Content",
      "numberOfItems": 3,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Service",
            "@id": "https://calzavara.ch/loesungen#website",
            "name": "Websites, die wirken",
            "description": "Individuelle Websites, die klar positioniert sind, sauber funktionieren und in jedem Detail passen. Kein Baukastensystem, kein Abo-Modell. Substanz, die bleibt.",
            "serviceType": "Webentwicklung",
            "provider": { "@id": "https://calzavara.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" },
            "offers": {
              "@type": "Offer",
              "priceCurrency": "CHF",
              "priceSpecification": { "@type": "UnitPriceSpecification", "description": "Fixpreis" }
            }
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Service",
            "@id": "https://calzavara.ch/loesungen#ki",
            "name": "KI-Lösungen für KMU",
            "description": "KI-Lösungen mit klarem Zweck, verständlicher Rolle und echtem Nutzen im Alltag. Keine Spielerei, kein Buzzword. Werkzeuge, die entlasten und verlässlich funktionieren.",
            "serviceType": "KI-Lösungen",
            "provider": { "@id": "https://calzavara.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" }
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Service",
            "@id": "https://calzavara.ch/loesungen#content",
            "name": "Texte, Bilder und Gestaltung",
            "description": "Der richtige Text, die klare Struktur, das starke Bild. Alles, was Form braucht – präzise, passend und ohne Umwege.",
            "serviceType": "Content-Erstellung",
            "provider": { "@id": "https://calzavara.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" }
          }
        }
      ]
    }
  ]
});
---

<Layout
  title="Websites, KI-Lösungen & Content-Gestaltung | Calzavara"
  description="Individuelle Websites, intelligente KI-Integrationen und exzellente Content-Gestaltung. Entdecken Sie digitale Lösungen mit Substanz aus St. Gallen. Persönlich & zum Fixpreis."
  keywords="Website erstellen lassen Schweiz, KI-Lösungen KMU, Content Erstellung Schweiz, Webdesign St. Gallen, Softwareentwicklung Freelancer, Website Fixpreis, Automatisierung"
  canonical="https://calzavara.ch/loesungen"
  ogTitle="Individuelle Lösungen für Ihre digitale Präsenz."
  ogDescription="Websites, KI und Content mit Charakter. Marco Calzavara entwickelt Lösungen, die wirklich zu Ihnen passen. Persönlich. Fixpreis. Ohne Baukasten."
  ogImageAlt="Calzavara – Individuelle Websites, KI & Content-Lösungen"
  twitterTitle="Websites, KI-Lösungen & Content-Gestaltung | Calzavara"
  twitterDescription="Websites, die ihren Job kennen. KI, die nicht nervt. Alles, dem Form fehlt. Fixpreis."
  schema={schema}
>
  <section class="section pt-sub loesungen-main" aria-labelledby="loesungen-title">
    <div class="hero-glow"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Lösungen' }
      ]} />

      <div class="fade-up loesungen-hero">
        <span class="badge badge--cyan">WOMIT ES AUFHÖRT</span>

        <h1 id="loesungen-title" style="margin-top: 15px;">
          Wenn es fertig ist,<br>
          <span class="gradient-text">fühlt es sich richtig an.</span>
        </h1>
        <p class="hero-lead">
          Fertig heisst hier nicht einfach abgeschlossen. Es heisst: kein Detail, das stört, kein Satz, der danebenliegt, kein Klick, der ins Leere führt. Erst wenn alles stimmt, ist ein Projekt wirklich fertig.
        </p>
      </div>

      <div class="fade-up delay-100 mt-80 accordion-wrapper">

        <div class="accordion" role="list">

          <div class="accordion-item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-1" class="accordion-header" aria-expanded="false" aria-controls="acc-1">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-1" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#00D2FF"/><stop offset="1" stop-color="#A64DFF"/>
                        </linearGradient>
                      </defs>
                      <rect x="2" y="3" width="20" height="14" rx="2" stroke="url(#acc-grad-1)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      <line x1="8" y1="21" x2="16" y2="21" stroke="url(#acc-grad-1)" stroke-width="1.8" stroke-linecap="round"/>
                      <line x1="12" y1="17" x2="12" y2="21" stroke="url(#acc-grad-1)" stroke-width="1.8"/>
                      <line x1="7" y1="11" x2="7" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="10" y1="9" x2="10" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="13" y1="7" x2="13" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="16" y1="9" x2="16" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </span>
                  <span>Websites, die wirken.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-1" class="accordion-content" role="region" aria-labelledby="acc-btn-1" aria-hidden="true">
              <p>
                Eine Website ist nicht einfach nur da. Sie zeigt, wer du bist, bevor du etwas sagen musst. Sie schafft Vertrauen, gibt Richtung und bringt Menschen dorthin, wo du sie haben willst.<br><br>
                Ich entwickle Websites, die klar positioniert sind, sauber funktionieren und in jedem Detail zu dir passen. Keine Vorlage, keine Kompromisse, kein Abo-Modell. Sondern eine Lösung, die Substanz hat und bleibt.
              </p>
            </div>
          </div>

          <div class="accordion-item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-2" class="accordion-header" aria-expanded="false" aria-controls="acc-2">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-2" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/>
                        </linearGradient>
                      </defs>
                      <circle cx="12" cy="12" r="2" stroke="url(#acc-grad-2)" stroke-width="1.8"/>
                      <circle cx="4.5" cy="8" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="4.5" cy="16" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="19.5" cy="8" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="19.5" cy="16" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="12" cy="3" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <line x1="10.3" y1="11" x2="6" y2="8.7" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="10.3" y1="13" x2="6" y2="15.3" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="13.7" y1="11" x2="18" y2="8.7" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="13.7" y1="13" x2="18" y2="15.3" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="12" y1="10" x2="12" y2="4.5" stroke="url(#acc-grad-2)" stroke-width="1.2"/>
                    </svg>
                  </span>
                  <span>KI, die nicht nervt.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-2" class="accordion-content" role="region" aria-labelledby="acc-btn-2" aria-hidden="true">
              <p>
                Viele KI-Lösungen beeindrucken kurz und verschwinden dann im Alltag. Nicht, weil die Technik zu wenig kann, sondern weil die Aufgabe nie klar war.<br><br>
                Ich entwickle KI-Lösungen, die nicht nur möglich, sondern sinnvoll sind. Mit einem klaren Zweck, einer verständlichen Rolle und einem echten Nutzen im Alltag. Keine Spielerei, kein Buzzword, kein zusätzlicher Lärm. Sondern Werkzeuge, die entlasten und verlässlich funktionieren.
              </p>
            </div>
          </div>

          <div class="accordion-item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-3" class="accordion-header" aria-expanded="false" aria-controls="acc-3">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-3" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#FF4D80"/><stop offset="1" stop-color="#FFC700"/>
                        </linearGradient>
                      </defs>
                      <polygon points="12 2 22 8.5 12 15 2 8.5" stroke="url(#acc-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><polyline points="2 13 12 19.5 22 13" stroke="url(#acc-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>Alles, was Form braucht.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-3" class="accordion-content" role="region" aria-labelledby="acc-btn-3" aria-hidden="true">
              <p>
                Nicht immer braucht es ein neues System. Manchmal braucht es einfach den richtigen Text. Eine klare Struktur. Ein starkes Bild. Oder eine Darstellung, die aus Komplexität endlich Klarheit macht.<br><br>
                Ich schaue hin, was fehlt, was stört und was besser werden muss. Dann bringe ich es in Form. Präzise, passend und ohne Umwege.
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <section class="section loesungen-section-cta" aria-labelledby="loesungen-cta-title">
    <div class="container">
      <div class="fade-up loesungen-cta">
        <span class="cta-label">BEREIT?</span>
        <h2 id="loesungen-cta-title" style="margin-bottom: 24px;">Weniger planen.<br><span class="gradient-text">Einfach anfangen.</span></h2>
        <div class="hero-cta-group loesungen-cta-group">
          <span class="reveal-mail btn btn-primary" role="button" tabindex="0" aria-label="Kontaktformular öffnen">Unverbindlich anfragen</span>
          <a href="/referenzen" class="btn btn-ghost">Referenzprojekte ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── MAIN SECTION ── */
  .loesungen-main {
    padding-bottom: 120px;
  }

  /* ── HERO ── */
  .loesungen-hero {
    text-align: left;
    max-width: 850px;
  }

  .hero-lead {
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 24px;
    max-width: 50ch;
  }

  /* ── ACCORDION WRAPPER ── */
  .accordion-wrapper {
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── ACCORDION ── */
  .accordion {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .accordion-h3 {
    margin: 0;
    padding: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }

  .accordion-item {
    position: relative;
    background: rgba(15, 15, 17, 0.4);
    border: 1px solid transparent;
    border-radius: 16px;
    background-image: linear-gradient(#0a0a0c, #0a0a0c), conic-gradient(from var(--border-angle, 0turn), rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.04) 20%, rgba(28, 161, 255, 0.1) 35%, rgba(153, 85, 255, 0.2) 50%, rgba(255, 110, 39, 0.1) 65%, rgba(255, 255, 255, 0.04) 80%, rgba(255, 255, 255, 0.04) 100%);
    background-origin: border-box;
    background-clip: padding-box, border-box;
    overflow: hidden;
    animation: borderRotate 24s linear infinite;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .accordion-item::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(166, 77, 255, 0.06),
      transparent 45%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 1;
  }

  .accordion-item:nth-child(odd) {
    animation-delay: -6s;
    animation-duration: 26s;
  }
  .accordion-item:nth-child(even) {
    animation-delay: -14s;
    animation-duration: 22s;
  }

  .accordion-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(153, 85, 255, 0.08);
    background-image: linear-gradient(#0a0a0c, #0a0a0c), conic-gradient(from var(--border-angle, 0turn), rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.08) 20%, rgba(28, 161, 255, 0.3) 35%, rgba(153, 85, 255, 0.6) 50%, rgba(255, 110, 39, 0.3) 65%, rgba(255, 255, 255, 0.08) 80%, rgba(255, 255, 255, 0.08) 100%);
  }

  .accordion-item:hover::after,
  .accordion-item.active::after {
    opacity: 1;
  }

  .accordion-item.active {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(153, 85, 255, 0.12), 0 5px 15px rgba(0, 0, 0, 0.5);
    background-image: linear-gradient(#0a0a0c, #0a0a0c), conic-gradient(from var(--border-angle, 0turn), rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.1) 20%, rgba(28, 161, 255, 0.4) 35%, rgba(153, 85, 255, 0.7) 50%, rgba(255, 110, 39, 0.4) 65%, rgba(255, 255, 255, 0.1) 80%, rgba(255, 255, 255, 0.1) 100%);
  }

  .accordion-item.active .accordion-title-wrapper > span:last-child {
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
  }

  .accordion-item.active .acc-icon-title {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .accordion-item.active .acc-icon-title svg {
    filter: saturate(1.5) brightness(1.1) drop-shadow(0 0 12px rgba(255, 255, 255, 0.2));
  }

  .accordion-header,
  .accordion-content {
    position: relative;
    z-index: 2;
  }

  .accordion-header {
    width: 100%;
    padding: 24px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .accordion-title-wrapper {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .accordion-title-wrapper span {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.5px;
    color: #fff;
    transition: color 0.3s ease;
  }

  .acc-icon-title {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  .acc-icon-title svg {
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.15));
    transition: all 0.4s ease;
  }

  .accordion-item:hover .acc-icon-title {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .accordion-item:hover .acc-icon-title svg {
    filter: saturate(1.5) brightness(1.1) drop-shadow(0 0 12px rgba(255, 255, 255, 0.2));
  }

  .accordion-icon {
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.3);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .accordion-item.active .accordion-icon {
    transform: rotate(45deg);
    color: #fff;
  }

  /* Performance fix: only transition max-height, not all properties */
  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .accordion-content p {
    padding: 0 32px 32px 112px; /* 60px icon + 20px gap + 32px left padding */
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    font-size: 1.05rem;
  }

  /* ── CTA SECTION ── */
  .loesungen-section-cta {
    padding-top: 80px;
    padding-bottom: 150px;
  }

  .loesungen-cta {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .loesungen-cta-group {
    justify-content: center;
  }

  /* ── TABLET WIDE (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .loesungen-main {
      padding-bottom: 88px;
    }
    .accordion-header {
      padding: 20px 28px;
    }
    .accordion-content p {
      padding: 0 28px 28px 100px;
    }
    .loesungen-section-cta {
      padding-top: 60px;
      padding-bottom: 100px;
    }
  }

  /* ── MOBILE (≤860px) ── */
  @media (max-width: 860px) {
    .loesungen-main {
      padding-bottom: 60px;
    }
    .hero-lead {
      font-size: 1rem;
      max-width: 100%;
    }
    .accordion-header {
      padding: 20px;
    }
    .accordion-content p {
      padding: 0 20px 24px 20px;
      margin-top: -8px;
    }
    .accordion-title-wrapper {
      gap: 16px;
    }
    .accordion-title-wrapper span {
      font-size: 1.15rem;
    }
    .acc-icon-title {
      width: 48px;
      height: 48px;
      border-radius: 12px;
    }
    .loesungen-section-cta {
      padding-top: 40px;
      padding-bottom: 80px;
    }
  }

  /* ── SMALL MOBILE (≤480px) ── */
  @media (max-width: 480px) {
    .loesungen-main {
      padding-bottom: 48px;
    }
    .hero-lead {
      font-size: 0.95rem;
      line-height: 1.65;
    }
    .loesungen-section-cta {
      padding-top: 40px;
      padding-bottom: 60px;
    }
    .loesungen-cta-group {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      margin-top: 24px;
    }
    .loesungen-cta-group .btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* ── VERY SMALL MOBILE (≤375px) ── */
  @media (max-width: 375px) {
    .loesungen-main {
      padding-bottom: 40px;
    }
    .hero-lead {
      font-size: 0.9rem;
    }
    .loesungen-section-cta {
      padding-top: 32px;
      padding-bottom: 48px;
    }
    .accordion-content p {
      font-size: 1rem;
    }
  }
</style>
