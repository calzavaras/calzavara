---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://laborium.ch/#website",
      "name": "Calzavara",
      "url": "https://laborium.ch",
      "inLanguage": "de-CH",
      "publisher": { "@id": "https://laborium.ch/#organization" },
      "potentialAction": {
        "@type": "CommunicateAction",
        "target": "https://laborium.ch/kontakt",
        "name": "Kontaktanfrage senden"
      }
    },
    {
      "@type": ["ProfessionalService", "Organization"],
      "@id": "https://laborium.ch/#organization",
      "name": "Calzavara",
      "url": "https://laborium.ch",
      "logo": {
        "@type": "ImageObject",
        "url": "https://laborium.ch/assets/calzavara-logo.svg"
      },
      "image": "https://laborium.ch/assets/calzavara-logo.svg",
      "description": "Was auch immer du digital vorhast, ich setze es um. Software, Texte, Branding, kleine Tools oder alles zusammen. KI-gestützt, persönlich betreut, aus St. Gallen.",
      "founder": { "@id": "https://laborium.ch/#person" },
      "foundingDate": "2025",
      "knowsAbout": ["KI-Lösungen", "Softwareentwicklung", "Webentwicklung", "Content-Erstellung", "Bildgenerierung", "Logo-Design", "Datenaufbereitung", "Automatisierung", "UX Design"],
      "numberOfEmployees": {
        "@type": "QuantitativeValue",
        "value": 1
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Wildeggstrasse 37",
        "addressLocality": "St. Gallen",
        "postalCode": "9000",
        "addressRegion": "SG",
        "addressCountry": "CH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "47.4245",
        "longitude": "9.3767"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "calzavara3830@gmail.com",
        "areaServed": "CH",
        "availableLanguage": ["German", "English"]
      },
      "priceRange": "$$",
      "areaServed": {
        "@type": "Country",
        "name": "Switzerland"
      },
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ]
    },
    {
      "@type": "Person",
      "@id": "https://laborium.ch/#person",
      "name": "Marco Calzavara",
      "givenName": "Marco",
      "familyName": "Calzavara",
      "jobTitle": "Gründer",
      "image": {
        "@type": "ImageObject",
        "url": "https://laborium.ch/assets/marco-calzavara-gruender-laborium-st-gallen.webp",
        "width": 768,
        "height": 1024
      },
      "url": "https://laborium.ch/ueber-uns",
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ],
      "worksFor": { "@id": "https://laborium.ch/#organization" }
    },
    {
      "@type": "WebPage",
      "@id": "https://laborium.ch/#webpage",
      "url": "https://laborium.ch/",
      "name": "Digitale Lösungen aus der Schweiz | Calzavara",
      "isPartOf": { "@id": "https://laborium.ch/#website" },
      "about": { "@id": "https://laborium.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-19",
      "description": "Was auch immer du digital vorhast, ich setze es um. Software, Texte, Branding, kleine Tools oder alles zusammen. KI-gestützt, persönlich betreut, echte Resultate.",
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["#hero-title", ".hero-content p", ".card h3"]
      }
    }
  ]
});
---

<Layout
  title="Digitale Lösungen aus der Schweiz | Calzavara"
  description="Website erstellen lassen in der Schweiz – persönlich, Fixpreis, kein Baukastensystem. Marco Calzavara baut Websites, die für dich arbeiten. Aus St. Gallen, für die ganze Schweiz."
  keywords="Website erstellen lassen Schweiz, Webseite erstellen St. Gallen, Freelancer Website Schweiz, Webdesign KMU Schweiz, digitale Lösungen Schweiz, Softwareentwicklung, KI-Lösungen, Branding, Fixpreis Website"
  canonical="https://laborium.ch/"
  ogTitle="Was gut gemacht ist, braucht keine Erklärung."
  ogDescription="Websites und digitale Lösungen, die wirklich zu dir passen. Persönlich. Fixpreis. Aus St. Gallen."
  ogImageAlt="Calzavara - Websites und digitale Lösungen aus der Schweiz"
  twitterTitle="Was gut gemacht ist, braucht keine Erklärung."
  twitterDescription="Websites und digitale Lösungen, die wirklich zu dir passen. Persönlich. Fixpreis. Aus St. Gallen."
  schema={schema}
>
  <section class="section pt-hero" aria-labelledby="hero-title">
    <div class="container fade-up">
      <div class="hero-glow"></div>

      <span class="badge badge--yellow">DIGITALE PRODUKTE. IM MASSANZUG.</span>

      <h1 id="hero-title" style="margin-top: 15px;">
        Ich arbeite weiter,<br>
        <span class="gradient-text">wo andere aufhören.</span>
      </h1>

      <p class="hero-lead">
        Digitale Produkte, Websites, Tools und Texte mit Charakter. Durchdacht bis in die Tiefe und gemacht, um zu bleiben.
      </p>

      <div class="hero-cta-group">
        <a href="/kontakt" class="btn btn-primary" title="Projekt starten">Projekt starten</a>
        <a href="/referenzen" class="btn btn-ghost" title="Arbeiten ansehen">Arbeiten ansehen</a>
      </div>
    </div>
  </section>

  <section class="section section-cards pt-compact" aria-labelledby="values-title">
    <div class="container">
      <h2 id="values-title" class="visually-hidden">So arbeite ich</h2>
      <div class="grid-3 values-grid">

        <article class="card fade-up">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-verstaendnis.svg'); mask-image: url('/assets/icons/icon-verstaendnis.svg');"></div></div>
          <span class="cta-label">VERSTÄNDNIS</span>
          <h3>Erst verstehen. Dann veredeln.</h3>
          <p>Ich denke mich in dein Vorhaben ein, erkenne, worauf es wirklich ankommt, und forme daraus eine Lösung mit Richtung, Tiefe und Substanz.</p>
        </article>

        <article class="card fade-up delay-100">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-anspruch.svg'); mask-image: url('/assets/icons/icon-anspruch.svg');"></div></div>
          <span class="cta-label">ANSPRUCH</span>
          <h3>Gut genug ist nie das Ziel.</h3>
          <p>Ich arbeite nicht für halbe Ergebnisse. Ich arbeite, bis Form, Funktion und Wirkung zusammenfinden und etwas entsteht, das wirklich trägt.</p>
        </article>

        <article class="card fade-up delay-200">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-zusammenarbeit.svg'); mask-image: url('/assets/icons/icon-zusammenarbeit.svg');"></div></div>
          <span class="cta-label">ZUSAMMENARBEIT</span>
          <h3>Klar im Denken. Direkt im Tun.</h3>
          <p>Keine Umwege, kein leeres Theater. Ich schätze klare Abmachungen, ehrlichen Austausch und eine Zusammenarbeit, die einfach ist und trotzdem Tiefe hat.</p>
        </article>

      </div>
    </div>
  </section>

<section class="section section-cta" aria-labelledby="cta-title">
    <div class="container">
      <div class="fade-up" style="text-align: center; max-width: 600px; margin: 0 auto;">
        <span class="cta-label">GENUG GELESEN?</span>
        <h2 id="cta-title">Lass uns etwas bauen,<br><span class="gradient-text">das bleibt.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <span class="reveal-mail btn btn-primary" role="button" tabindex="0" aria-label="E-Mail-Adresse anzeigen">Gespräch starten</span>
          <a href="/referenzen" class="btn btn-ghost">Arbeiten ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
/* Index-spezifische Abstände */
  .section-cards {
    padding-top: 140px;
    padding-bottom: 120px;
  }

  .values-grid {
    gap: 32px;
  }

  .values-grid .card {
    min-height: auto !important; /* Force override of global min-height */
    height: auto; /* Allow natural height */
    padding: 32px 28px;
  }

  .values-grid .card h3 {
    letter-spacing: -0.5px;
    margin-bottom: 12px;
  }
  
  .values-grid .card p {
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
  }

  .values-grid .card-icon {
    margin-bottom: 20px;
  }


.section-cta {
    padding-top: 80px;
    padding-bottom: 150px;
  }

  /* Hero: mehr Luft zum Text */
  .hero-lead {
    max-width: 52ch;
    font-size: 1.1rem;
    line-height: 1.75;
    margin-bottom: 0;
  }

  /* CTA-Block: Label enger zum Titel */
  .cta-label {
    margin-bottom: 8px;
  }

  /* Tablet: 2 Spalten statt 3 bei mittlerer Breite */
  @media (max-width: 860px) and (min-width: 641px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: Hero-Text etwas kleiner */
  @media (max-width: 768px) {
    .hero-lead {
      font-size: 1rem;
    }
    .section-cards {
      padding-top: 40px;
      padding-bottom: 50px;
    }
    .section-cta {
      padding-top: 40px;
      padding-bottom: 70px;
    }
    .cta-mail {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .cta-mail {
      font-size: 0.95rem;
    }
  }
</style>
