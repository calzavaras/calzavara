---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://calzavara.ch/#website",
      "name": "Calzavara",
      "url": "https://calzavara.ch",
      "inLanguage": "de-CH",
      "publisher": { "@id": "https://calzavara.ch/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://calzavara.ch/referenzen?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService", "Organization"],
      "@id": "https://calzavara.ch/#organization",
      "name": "Calzavara | Marco Calzavara",
      "url": "https://calzavara.ch",
      "logo": {
        "@type": "ImageObject",
        "url": "https://calzavara.ch/assets/calzavara-logo.svg"
      },
      "image": "https://calzavara.ch/assets/calzavara-logo.svg",
      "description": "Exklusive Websites, KI-Lösungen und Softwareentwicklung aus St. Gallen. Marco Calzavara entwickelt digitale Produkte mit Substanz – persönlich, zum Fixpreis, ohne Baukasten.",
      "founder": { "@id": "https://calzavara.ch/#person" },
      "foundingDate": "2025",
      "knowsAbout": ["Webdesign", "Softwareentwicklung", "KI-Lösungen", "Branding", "User Experience Design", "Automatisierung"],
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": 1 },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Wildeggstrasse 37",
        "addressLocality": "St. Gallen",
        "postalCode": "9000",
        "addressRegion": "SG",
        "addressCountry": "CH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "47.4245",
        "longitude": "9.3767"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "calzavara3830@gmail.com",
        "areaServed": "CH",
        "availableLanguage": ["German", "English"]
      },
      "priceRange": "$$",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Digitale Dienstleistungen",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Website Erstellung (Individualentwicklung)" }
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "KI-Integration & Automatisierung" }
          }
        ]
      },
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ]
    },
    {
      "@type": "Person",
      "@id": "https://calzavara.ch/#person",
      "name": "Marco Calzavara",
      "jobTitle": "Full-Stack Developer & Gründer",
      "worksFor": { "@id": "https://calzavara.ch/#organization" }
    },
    {
      "@type": "WebPage",
      "@id": "https://calzavara.ch/#webpage",
      "url": "https://calzavara.ch/",
      "name": "Websites & Digitale Lösungen | Marco Calzavara – St. Gallen",
      "isPartOf": { "@id": "https://calzavara.ch/#website" },
      "about": { "@id": "https://calzavara.ch/#organization" },
      "description": "Websites und digitale Lösungen zum Fixpreis. Marco Calzavara: Ihr Partner für Webentwicklung, KI-Integration und exklusives Design aus St. Gallen.",
      "inLanguage": "de-CH"
    }
  ]
});
---

<Layout
  title="Websites & Digitale Lösungen | Marco Calzavara – St. Gallen"
  description="Professionelle Websites & KI-Lösungen zum Fixpreis. Marco Calzavara entwickelt digitale Produkte mit Substanz – persönlich, exklusiv, ohne Baukasten. Jetzt anfragen."
  keywords="Website erstellen lassen Schweiz, Webseite erstellen St. Gallen, Webdesign Freelancer Schweiz, Softwareentwicklung St. Gallen, KI Lösungen KMU, digitale Lösungen, Website Fixpreis"
  canonical="https://calzavara.ch/"
  ogTitle="Websites & Digitale Lösungen, die wirklich zu dir passen."
  ogDescription="Kein Baukasten, keine Kompromisse. Marco Calzavara entwickelt digitale Produkte mit Substanz. Persönlich. Fixpreis. Aus St. Gallen."
  ogImageAlt="Calzavara - Exklusive Websites & Digitale Lösungen"
  twitterTitle="Websites & Digitale Lösungen | Marco Calzavara"
  twitterDescription="Was gut gemacht ist, braucht keine Erklärung. Websites und KI-Lösungen aus St. Gallen."
  schema={schema}
>
  <section class="section pt-hero" aria-labelledby="hero-title">
    <div class="hero-glow"></div>
    <div class="container fade-up">

      <span class="badge badge--yellow">DIGITALE PRODUKTE. IM MASSANZUG.</span>

      <h1 id="hero-title" style="margin-top: 15px;">
        Ich arbeite dort weiter,<br>
        <span class="gradient-text">wo andere aufhören.</span>
      </h1>

      <p class="hero-lead">
        Websites, digitale Lösungen, Tools und Texte mit Charakter. Durchdacht bis ins Detail und gemacht, um zu bleiben.
      </p>

      <div class="hero-cta-group">
        <a href="/kontakt" class="btn btn-primary" title="Projekt starten">Projekt starten</a>
        <a href="/referenzen" class="btn btn-ghost" title="Arbeiten ansehen">Arbeiten ansehen</a>
      </div>
    </div>
  </section>

  <section class="section section-cards pt-compact" aria-labelledby="values-title">
    <div class="container">
      <h2 id="values-title" class="visually-hidden">So arbeite ich</h2>
      <div class="grid-3 values-grid">

        <article class="card fade-up">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-verstaendnis.svg'); mask-image: url('/assets/icons/icon-verstaendnis.svg');"></div></div>
          <span class="cta-label">VERSTÄNDNIS</span>
          <h3>Erst verstehen. Dann veredeln.</h3>
          <p>Ich denke mich in dein Vorhaben ein, erkenne, worauf es wirklich ankommt, und entwickle daraus eine Lösung mit Richtung, Tiefe und Substanz.</p>
        </article>

        <article class="card fade-up delay-100">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-anspruch.svg'); mask-image: url('/assets/icons/icon-anspruch.svg');"></div></div>
          <span class="cta-label">ANSPRUCH</span>
          <h3>Gut genug ist nie das Ziel.</h3>
          <p>Ich arbeite nicht für halbe Ergebnisse. Ich arbeite, bis Form, Funktion und Wirkung zusammenfinden und etwas entsteht, das langfristig trägt.</p>
        </article>

        <article class="card fade-up delay-200">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-zusammenarbeit.svg'); mask-image: url('/assets/icons/icon-zusammenarbeit.svg');"></div></div>
          <span class="cta-label">ZUSAMMENARBEIT</span>
          <h3>Klar im Denken. Direkt im Tun.</h3>
          <p>Keine Umwege, kein leeres Theater. Ich schätze klare Abmachungen, ehrlichen Austausch und eine Zusammenarbeit, die unkompliziert ist und trotzdem Tiefe hat.</p>
        </article>

      </div>
    </div>
  </section>

<section class="section section-cta" aria-labelledby="cta-title">
    <div class="container">
      <div class="fade-up" style="text-align: center; max-width: 600px; margin: 0 auto;">
        <span class="cta-label">GENUG GELESEN?</span>
        <h2 id="cta-title">Lass uns etwas bauen,<br><span class="gradient-text">das bleibt.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <span class="reveal-mail btn btn-primary" role="button" tabindex="0" aria-label="E-Mail-Adresse anzeigen">Gespräch starten</span>
          <a href="/referenzen" class="btn btn-ghost">Arbeiten ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
/* ── DESKTOP BASE ── */
.section-cards {
  padding-top: 80px;
  padding-bottom: 120px;
}
.section-cta {
  padding-top: 80px;
  padding-bottom: 150px;
}
.values-grid {
  gap: 32px;
}
.values-grid .card {
  min-height: auto !important;
  height: auto;
  padding: 32px 28px;
}
.values-grid .card h3 {
  letter-spacing: -0.5px;
  margin-bottom: 12px;
}
.values-grid .card p {
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.7;
}
.values-grid .card-icon {
  margin-bottom: 20px;
}
.hero-lead {
  max-width: 52ch;
  font-size: 1.1rem;
  line-height: 1.75;
  margin-bottom: 0;
}
.cta-label {
  margin-bottom: 8px;
}

/* ── TABLET WIDE (769–1024px) ── */
@media (max-width: 1024px) and (min-width: 769px) {
  .section-cards {
    padding-top: 60px;
    padding-bottom: 88px;
  }
  .section-cta {
    padding-top: 60px;
    padding-bottom: 100px;
  }
  .values-grid .card {
    padding: 28px 24px;
  }
}

/* ── MOBILE (≤860px) ── */
@media (max-width: 860px) {
  .hero-lead {
    font-size: 1rem;
    max-width: 100%;
  }
  .hero-cta-group {
    margin-top: 28px;
    gap: 12px;
  }
  .section-cards {
    padding-top: 40px;
    padding-bottom: 60px;
  }
  .section-cta {
    padding-top: 40px;
    padding-bottom: 80px;
  }
  .values-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .values-grid .card {
    padding: 28px 22px;
  }
}

/* ── SMALL MOBILE (≤480px) ── */
@media (max-width: 480px) {
  .hero-lead {
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .hero-cta-group {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    margin-top: 24px;
  }
  .hero-cta-group .btn {
    width: 100%;
    justify-content: center;
  }
  .section-cta {
    padding-bottom: 60px;
  }
  .values-grid {
    gap: 14px;
  }
  .values-grid .card {
    padding: 24px 20px;
  }
}

/* ── VERY SMALL MOBILE (≤375px) ── */
@media (max-width: 375px) {
  .hero-lead {
    font-size: 0.9rem;
  }
  .section-cards {
    padding-top: 32px;
    padding-bottom: 48px;
  }
  .section-cta {
    padding-top: 32px;
    padding-bottom: 48px;
  }
  .values-grid .card {
    padding: 22px 18px;
  }
}
</style>
