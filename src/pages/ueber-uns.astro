---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/ueber-uns#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Über mich", "item": "https://www.nigredo.ch/ueber-uns" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.nigredo.ch/#person",
      "name": "Marco Calzavara",
      "givenName": "Marco",
      "familyName": "Calzavara",
      "jobTitle": "Gründer, Ideengeber und Teamleiter",
      "description": "Macher und Gründer aus St. Gallen. Führt ein Expertenteam in der Verwaltung, entwickelt Abteilungen weiter und bringt mit Nigredo, HappyPath GmbH, KI und einem starken IT-Netzwerk Ideen schnell in Ergebnisse.",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp",
        "width": 768,
        "height": 1024
      },
      "url": "https://www.nigredo.ch/ueber-uns",
      "worksFor": { "@id": "https://www.nigredo.ch/#organization" },
      "knowsAbout": ["Abteilungsentwicklung", "Führung", "Content-Erstellung", "Bildgenerierung", "Software Development", "Web Development", "UX Design", "Datenaufbereitung", "KI-Lösungen"],
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "St. Gallen",
        "postalCode": "9000",
        "addressCountry": "CH"
      }
    },
    {
      "@type": "AboutPage",
      "@id": "https://www.nigredo.ch/ueber-uns#webpage",
      "name": "Über mich | Marco Calzavara | Nigredo",
      "url": "https://www.nigredo.ch/ueber-uns",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/ueber-uns#breadcrumb" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-04-26",
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".pc-name", ".belief-title"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/#person" }
    }
  ]
});
---

<Layout
  title="Über mich | Marco Calzavara | Nigredo"
  description="Marco Calzavara – Macher, Ideengeber und Gründer aus St. Gallen. 15 Jahre Führung, mehrere Firmen, Verwaltungsexpertise, KI und ein starkes IT-Netzwerk."
  keywords="Marco Calzavara, Nigredo Gründer, Website Freelancer St. Gallen, Webdesign Schweiz, KI-Lösungen Schweiz, persönliche Betreuung, Softwareentwicklung KMU"
  canonical="https://www.nigredo.ch/ueber-uns"
  ogTitle="Ein Mensch. 1001 Ideen."
  ogDescription="Macher, Ideengeber und Gründer aus St. Gallen. Verwaltungsexpertise, mehrere Firmen, KI und ein Netzwerk, das Ideen schnell in Ergebnisse bringt."
  ogType="profile"
  ogImage="https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp"
  ogImageAlt="Marco Calzavara - Gründer von Nigredo"
  ogImageWidth="768"
  ogImageHeight="1024"
  twitterTitle="Ein Mensch. 1001 Ideen."
  twitterDescription="Macher, Ideengeber und Gründer aus St. Gallen. Verwaltungsexpertise, KI und ein starkes IT-Netzwerk."
  schema={schema}
>
  <section class="section pt-sub about-hero" aria-labelledby="about-title">
    <div class="hero-glow"></div>
    <div class="container about-hero__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Über mich' }
      ]} />

      <!-- Hero -->
      <div class="fade-up home-hero__inner about-hero__intro">
        <span class="badge badge--pink">PROFIL</span>
        <h1 id="about-title" class="home-hero__title about-hero__title">
          Ein Mensch.<br>
          <span class="gradient-text">1001 Ideen.</span>
        </h1>
      </div>

      <!-- Main Profile & Intro Grid -->
      <div class="au-main-grid mt-80">
        <div class="au-profile-column fade-up delay-100">
          <div class="au-photo-container">
            <div class="au-photo-aura"></div>
            <div class="au-photo-circle-wrap">
              <img
                src="/assets/marco-calzavara-gruender-nigredo-st-gallen.webp"
                alt="Marco Calzavara"
                class="au-photo-circle lightbox-trigger"
                width="768"
                height="1024"
                loading="lazy"
              >
            </div>
          </div>
          <div class="au-profile-info">
            <h2 class="au-name">Marco Calzavara</h2>
            <p class="au-role">Ideengeber. Gründer. Umsetzer.</p>
          </div>
        </div>

        <div class="au-content-column fade-up delay-150">
          <div class="au-statement">
            <blockquote class="hero-lead about-statement__quote">
              «Gute Ideen dürfen am Anfang ruhig etwas spinnen. Entscheidend ist, wer sie danach auf den Boden bringt.»
            </blockquote>
          </div>
          
          <div class="au-bio">
            <p class="au-bio-intro">
              Ich bin ein Macher mit Ideenüberschuss: kreativ, neugierig, manchmal unkonventionell und allergisch auf «Das haben wir schon immer so gemacht». Beim Kanton führe ich ein Expertenteam; mit Nigredo und HappyPath bringe ich Ideen, KI, Gestaltung und starke Informatikfachleute zusammen. Mein Ding: Möglichkeiten erkennen, Menschen verbinden und daraus schnell etwas machen, das funktioniert und Freude macht.
            </p>

            <details class="au-bio-more">
              <summary>
                <span>Mehr erfahren</span>
              </summary>
              <div class="au-bio-more__content">
                <p>
                  Hauptberuflich arbeite ich in der kantonalen Verwaltung, führe ein Expertenteam und bin für Abteilungsentwicklung zuständig. Das hat mich geprägt: klar denken, Menschen mitnehmen, Komplexität sortieren und Dinge so bauen, dass sie im Alltag funktionieren.
                </p>
                <p>
                  Daneben entstehen Unternehmen, Projekte und digitale Lösungen. Mehrere Firmen gegründet, einige verkauft, viel umgesetzt und noch mehr verstanden. Mit einem Kollegen führe ich ausserdem die Software-Unternehmung HappyPath GmbH.
                </p>
                <p>
                  Ich muss nicht alles allein können. Ich muss erkennen, was möglich ist, die richtigen Menschen verbinden und dafür sorgen, dass es passiert. Wenn ich etwas anpacke, bleibt es nicht monatelang in schönen Konzepten liegen. Kein grosses Theater. Gute Arbeit.
                </p>
              </div>
            </details>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="au-stats-grid mt-80 fade-up delay-200">
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">15</span>
            <span class="au-stat-desc">Jahre Fachwissen, Führung und Praxis</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">3×</span>
            <span class="au-stat-desc">Firmen gegründet, aufgebaut, verkauft</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">1</span>
            <span class="au-stat-desc">Ideengeber, Netzwerk, direkte Verantwortung</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">∞</span>
            <span class="au-stat-desc">Neugier, Initiative und Umsetzungsdrang</span>
          </div>
        </div>
      </div>

      <!-- Principles -->
      <div class="mt-80 fade-up delay-300">
        <span class="badge badge--pink">PRINZIPIEN</span>
        <h2>Woran ich glaube.</h2>
        <div class="grid-3">
          <article class="card au-principle-card">
            <div class="au-principle-number">01</div>
            <h3><span>Anpacken</span> schlägt Abwarten.</h3>
            <p class="au-principle-text">Viele gute Ideen scheitern nicht an der Technik, sondern daran, dass niemand den ersten Schritt macht.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">02</div>
            <h3>Technik braucht <span>Richtung</span>.</h3>
            <p class="au-principle-text">KI, Software und gute Leute können viel. Entscheidend ist, wofür man sie einsetzt.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">03</div>
            <h3>Kein Theater. <span>Ergebnis</span>.</h3>
            <p class="au-principle-text">Klar denken, schnell starten, sauber umsetzen. Am Ende soll etwas stehen, das man gern zeigt.</p>
          </article>
        </div>
      </div>

      <!-- CTA -->
      <div class="section about-final-section fade-up">
        <div class="section-cta about-final-cta">
          <span class="cta-label">Und jetzt?</span>
          <h2>Noch keine fertige Idee?<br><span>Genau richtig.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt" class="btn btn-primary">Direkt schreiben</a>
            <a href="/referenzen" class="btn btn-ghost">Projekte ansehen</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .about-hero {
    padding-top: 150px;
    padding-bottom: 48px;
  }

  .about-hero__container {
    position: relative;
    width: 100%;
  }

  .about-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .about-hero .badge {
    margin-bottom: 1rem;
  }

  .about-hero__intro {
    width: 100%;
    max-width: 940px;
  }

  .about-hero__title {
    max-width: 940px;
    font-size: clamp(2.9rem, 5.35vw, 4.85rem);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .about-hero .gradient-text {
    background: linear-gradient(to right, #ff4d80, #a64dff, #ff4d80);
    background-size: 200% auto;
    animation: gradientPan 24s linear infinite;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Main Layout Grid */
  .au-main-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: clamp(44px, 6vw, 80px);
    align-items: start;
    margin-top: 72px;
  }

  /* Profile Column */
  .au-profile-column {
    position: sticky;
    top: 132px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .au-photo-container {
    position: relative;
    width: 252px;
    height: 252px;
    margin-bottom: 26px;
  }

  .au-photo-aura {
    position: absolute;
    inset: -12px;
    background: linear-gradient(135deg, #FF4D80, #A64DFF);
    border-radius: 50%;
    filter: blur(24px);
    opacity: 0.16;
    animation: aura-pulse 8s infinite alternate ease-in-out;
  }

  @keyframes aura-pulse {
    0% { transform: scale(1); opacity: 0.15; }
    100% { transform: scale(1.1); opacity: 0.25; }
  }

  .au-photo-circle-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #050505;
    z-index: 1;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 18px 45px rgba(0, 0, 0, 0.28);
  }

  .au-photo-circle {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    cursor: zoom-in;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .au-photo-circle:hover { transform: scale(1.055); }

  .au-name {
    font-size: clamp(1.28rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 7px;
    color: #fff;
  }

  .au-role {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.42);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Content Column */
  .au-statement {
    margin-bottom: 32px;
  }

  .au-statement .about-statement__quote {
    max-width: 760px;
    font-size: clamp(1.03rem, 1.15vw, 1.2rem);
    line-height: 1.65;
    color: rgba(245, 245, 247, 0.92);
    font-style: italic;
    margin: 0;
    padding: 28px 32px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.016)),
      #0a0a0c;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .au-bio p {
    max-width: 760px;
    font-size: clamp(1.03rem, 1.15vw, 1.2rem);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .au-bio-intro {
    color: rgba(245, 245, 247, 0.76);
    margin-bottom: 0;
  }

  .au-bio strong {
    color: #fff;
    font-weight: 700;
  }

  .au-bio-more {
    max-width: 760px;
    margin-top: 18px;
    padding-top: 2px;
  }

  .au-bio-more summary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 40px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    list-style: none;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .au-bio-more summary::-webkit-details-marker {
    display: none;
  }

  .au-bio-more summary::after {
    content: "+";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    color: #050505;
    background: linear-gradient(135deg, #FF4D80 0%, #A64DFF 100%);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    transition: transform 0.25s ease;
  }

  .au-bio-more summary:hover {
    color: #fff;
    transform: translateY(-1px);
  }

  .au-bio-more[open] summary::after {
    content: "−";
    transform: rotate(180deg);
  }

  .au-bio-more__content {
    margin-top: 16px;
    padding: 22px 24px 4px;
    border-left: 1px solid rgba(255, 77, 128, 0.34);
    background:
      linear-gradient(90deg, rgba(255, 77, 128, 0.045), rgba(166, 77, 255, 0.018) 48%, transparent);
  }

  .au-bio-more__content p {
    font-size: clamp(0.96rem, 1.05vw, 1.02rem);
    line-height: 1.66;
    color: rgba(255, 255, 255, 0.58);
    margin-bottom: 18px;
  }

  /* Stats Grid */
  .au-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 18px;
    margin-top: 80px;
  }

  .au-stat-card {
    padding: 0;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.016)),
      #0a0a0c;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      background 0.35s ease;
  }

  .au-stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  .au-stat-inner {
    padding: 30px 24px;
    text-align: center;
    height: 100%;
    box-sizing: border-box;
  }

  .au-stat-value {
    font-size: clamp(2.55rem, 4.2vw, 3rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 10px;
    display: block;
    background: linear-gradient(135deg, #FF4D80, #A64DFF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .au-stat-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.48);
    line-height: 1.45;
  }

  .mt-80.fade-up.delay-300 {
    margin-top: 84px;
  }

  /* Principles specific */
  .au-principle-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.018)),
      #0a0a0c;
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
    height: 100%;
    box-sizing: border-box;
  }

  .au-principle-card::before,
  .au-principle-card::after {
    display: none;
  }

  .au-principle-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  .au-principle-number {
    font-size: 0.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, #FF4D80 0%, #A64DFF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
    display: block;
  }

  .au-principle-card h3 {
    font-size: clamp(1.23rem, 2.2vw, 1.48rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }

  .au-principle-card h3 span {
    background: linear-gradient(135deg, #FF4D80 0%, #A64DFF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    font-style: normal;
  }

  .au-principle-text {
    font-size: 0.95rem;
    line-height: 1.62;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .about-final-section {
    margin-top: 72px;
    padding-top: 0;
    padding-bottom: 118px;
  }

  .about-final-cta {
    max-width: 660px;
  }

  .about-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .about-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .about-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .about-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .about-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.15));
  }

  .about-final-cta .btn-ghost:hover {
    animation: none;
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3));
    box-shadow: 0 10px 26px rgba(255, 255, 255, 0.08);
  }

  .about-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .au-main-grid {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .au-profile-column {
      position: static;
    }
  }

  @media (max-width: 860px) {
    .about-hero {
      padding-top: 132px;
      padding-bottom: 42px;
    }

    .about-hero__title {
      font-size: clamp(2.55rem, 10vw, 3.8rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .au-main-grid {
      margin-top: 52px;
    }

    .au-stats-grid {
      margin-top: 64px;
    }

    .mt-80.fade-up.delay-300 {
      margin-top: 70px;
    }
  }

  @media (max-width: 600px) {
    .about-hero__title {
      font-size: clamp(2.35rem, 13vw, 3.25rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .au-photo-container {
      width: 204px;
      height: 204px;
    }

    .au-statement .about-statement__quote {
      padding: 24px;
      font-size: 1.02rem;
      line-height: 1.6;
    }

    .au-bio-more__content {
      padding: 20px 0 2px 18px;
    }

    .au-stat-value {
      font-size: 2.5rem;
    }

    .about-final-section {
      margin-top: 56px;
      padding-top: 0;
      padding-bottom: 88px;
    }

    .about-final-cta h2 {
      font-size: clamp(1.8rem, 11vw, 2.5rem);
    }
  }
</style>
