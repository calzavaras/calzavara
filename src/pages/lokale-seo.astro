---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/lokale-seo/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://www.nigredo.ch/digitale-loesungen/" },
        { "@type": "ListItem", "position": 3, "name": "Lokal gefunden werden", "item": pageUrl }
      ]
    },
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      "name": "Lokale Sichtbarkeit für Selbständige, KMU, Praxen, Dienstleister und Vereine",
      "serviceType": "Lokale SEO, regionale Sichtbarkeit und klare Websites für lokale Angebote",
      "description": "Lokale Sichtbarkeit für Selbständige, KMU, Praxen, Dienstleister, Vereine und Menschen mit klaren Vorhaben. Für mehr Verständnis, Vertrauen und passende Anfragen aus der Region.",
      "provider": { "@id": "https://www.nigredo.ch/#organization" },
      "areaServed": [
        { "@type": "City", "name": "St. Gallen" },
        { "@type": "AdministrativeArea", "name": "Ostschweiz" },
        { "@type": "Country", "name": "Switzerland" }
      ],
      "audience": {
        "@type": "Audience",
        "audienceType": "Einzelfirmen, KMU, Praxen, Dienstleister, Vereine und Privatpersonen mit öffentlichem Vorhaben"
      }
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Lokal sichtbar werden | Nigredo",
      "description": "Lokale Sichtbarkeit für Selbständige, KMU, Praxen, Dienstleister, Vereine und Menschen mit klaren Vorhaben. Für mehr Verständnis, Vertrauen und passende Anfragen aus der Region.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "about": { "@id": `${pageUrl}#service` },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-05",
      "dateModified": "2026-05-06",
      "isAccessibleForFree": true,
      "mainEntity": { "@id": `${pageUrl}#service` }
    }
  ]
});
---

<Layout
  title="Lokal sichtbar werden | Nigredo"
  description="Lokal gefunden werden in St. Gallen, der Ostschweiz und der Schweiz. Website, Inhalte und Google-Präsenz klar ausrichten."
  canonical={pageUrl}
  ogTitle="Lokal sichtbar werden | Nigredo"
  ogDescription="Für Selbständige, KMU, Praxen, Dienstleister, Vereine und klare Vorhaben: lokal besser gefunden und schneller verstanden werden."
  twitterTitle="Lokal sichtbar werden | Nigredo"
  twitterDescription="Lokal besser gefunden und schneller verstanden werden."
  schema={schema}
>
  <section class="section sub-page-hero" aria-labelledby="lokal-title">
    <div class="hero-glow"></div>
    <div class="container sub-page-hero__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Lösungen', href: '/digitale-loesungen/' },
        { label: 'Lokal gefunden werden' }
      ]} />

      <div class="fade-up sub-page-hero__content">
        <span class="badge badge--pink">LOKAL GEFUNDEN WERDEN</span>
        <h1 id="lokal-title" class="sub-page-hero__title">
          Lokal sichtbar werden.<br class="hidden-mobile">
          <span class="gradient-text">In deiner Region.</span>
        </h1>
        <p class="hero-lead sub-page-hero__lead">
          Wenn jemand in St. Gallen, der Ostschweiz oder deiner Region nach deinem Angebot sucht, ist deine Website klar und vertrauenswürdig genug, damit er bleibt? Ich sorge dafür, dass du regional auffindbar bist und sofort richtig verstanden wirst.
        </p>
        <div class="hero-cta-group">
          <a href="/kontakt/" class="btn btn-primary">Lass mich ansehen, wie du lokal dastehst</a>
          <a href="/referenzen/" class="btn btn-ghost">Referenzen ansehen</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-compact" aria-labelledby="intro-title">
    <div class="container">
      <div class="fade-up max-w-copy">
        <span class="cta-label">Relevanz statt Reichweite</span>
        <h2 id="intro-title" class="mb-4">Nicht überall sichtbar. Sondern dort, wo es zählt.</h2>
        <p>
          Lokale Sichtbarkeit bedeutet nicht, überall zu erscheinen. Es bedeutet, von den richtigen Menschen gefunden zu werden. Von jemandem in St. Gallen, Thurgau, Appenzell oder Rheintal, der gerade genau das sucht, was du anbietest.
        </p>
        <p>
          Eine gute lokale Website zeigt klar, was du tust, wo du tätig bist und wie man zu dir kommt. Google versteht das. Und Menschen, die sich für dein Angebot entscheiden wollen, auch.
        </p>

        <div class="seo-note fade-up delay-100 mt-10">
          <span class="seo-note__label">Kurz gesagt</span>
          <p>Gefunden werden reicht nicht. Entscheidend ist, was nach dem Klick passiert.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-values" aria-labelledby="lokal-output">
    <div class="container">
      <div class="fade-up mb-10">
        <span class="cta-label">Was besser wird</span>
        <h2 id="lokal-output">Was lokale Sichtbarkeit konkret besser macht.</h2>
      </div>
      <div class="grid-3">
        <article class="card value-card fade-up" style="--icon-gradient: linear-gradient(135deg, #00d2ff 0%, #a64dff 100%); --icon-shadow: rgba(0, 210, 255, 0.34);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-local-seo-basis.svg'); mask-image: url('/assets/icons/icon-local-seo-basis.svg');"></div></div>
          <span class="cta-label">Region</span>
          <h3>Dein Ort wird Teil der Aussage.</h3>
          <p>St. Gallen, Thurgau, Appenzell, Rheintal oder ein klar definiertes Einzugsgebiet: Region wird dort eingebunden, wo sie echten Kontext gibt – nicht als Dekoration. Einschliesslich Google Business Profil, wenn das für dein Angebot relevant ist.</p>
        </article>
        <article class="card value-card fade-up delay-100" style="--icon-gradient: linear-gradient(135deg, #ffc700 0%, #ff4d80 100%); --icon-shadow: rgba(196, 77, 255, 0.34);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-local-standort.svg'); mask-image: url('/assets/icons/icon-local-standort.svg');"></div></div>
          <span class="cta-label">Inhalt</span>
          <h3>Deine Website sagt klarer, wofür du stehst.</h3>
          <p>Viele Websites bleiben zu allgemein. Sie klingen austauschbar, erklären zu wenig oder verwenden Begriffe, nach denen niemand sucht. Ich schärfe Inhalte so, dass dein Angebot verständlicher wird. Für Besucher, für Google und für Menschen, die eine Entscheidung treffen wollen.</p>
        </article>
        <article class="card value-card fade-up delay-200" style="--icon-gradient: linear-gradient(135deg, #a64dff 0%, #ff4d80 100%); --icon-shadow: rgba(255, 77, 128, 0.32);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-local-anfrage.svg'); mask-image: url('/assets/icons/icon-local-anfrage.svg');"></div></div>
          <span class="cta-label">Struktur</span>
          <h3>Besucher finden schneller den nächsten Schritt.</h3>
          <p>Eine lokale Website muss führen: zu deiner Leistung, zu deinem Standort, zu einem Termin, zu einer Anfrage oder zu einem ersten Gespräch. Je klarer dieser Weg ist, desto weniger Menschen springen ab.</p>
        </article>
        <article class="card value-card fade-up delay-300" style="--icon-gradient: linear-gradient(135deg, #00d2ff 0%, #ffc700 100%); --icon-shadow: rgba(255, 199, 0, 0.30);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-kmu-vertrauen.svg'); mask-image: url('/assets/icons/icon-kmu-vertrauen.svg');"></div></div>
          <span class="cta-label">Vertrauen</span>
          <h3>Der erste Eindruck bekommt Gewicht.</h3>
          <p>Wer lokal sucht, vergleicht oft mehrere Anbieter. Darum muss deine Website nicht nur auffindbar sein, sondern glaubwürdig wirken: mit klarer Sprache, echten Informationen, passenden Nachweisen und einem Auftritt, der so sorgfältig ist wie deine Arbeit.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section final-cta-section" aria-labelledby="cta-title">
    <div class="container">
      <div class="final-cta-content final-cta-content--centered fade-up">
        <span class="cta-label">FRAGE?</span>
        <h2 id="cta-title">Lass uns ansehen,<br><span>was lokal möglich ist.</span></h2>
        <div class="hero-cta-group">
          <a href="/kontakt/" class="btn btn-primary">Direkt anfragen</a>
          <a href="/digitale-loesungen/" class="btn btn-ghost">Lösungen ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-values {
    padding-top: clamp(40px, 6vw, 60px);
    padding-bottom: clamp(60px, 8vw, 80px);
  }

  .card p {
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    margin-bottom: 0;
  }

</style>
