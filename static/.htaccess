# www.nigredo.ch - Apache Konfiguration
# Saubere URLs ohne .html Endung

Options -MultiViews -Indexes
RewriteEngine On

# HTTPS erzwingen
# Einige Hoster terminieren SSL vor Apache. In dem Fall bleibt %{HTTPS} intern "off",
# obwohl der Browser bereits per HTTPS verbunden ist. X-Forwarded-Proto verhindert Redirect-Loops.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Kanonische Domain erzwingen
RewriteCond %{HTTP_HOST} !^www\.nigredo\.ch$ [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# Kanonische Directory-URLs mit Trailing Slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ /$1/ [L,R=301]

# Astro Directory-Build: /pfad -> /pfad/index.html
# Dadurch bleiben saubere URLs ohne Slash möglich, obwohl der Build Verzeichnisse erzeugt.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+)$ /$1/index.html [L]

# 404 Fehlerseite
ErrorDocument 404 /404.html

# Sicherheitsheader
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), display-capture=(), interest-cohort=(), idle-detection=(), serial=(), ambient-light-sensor=(), battery=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' https://cloud.umami.is 'sha256-egBC3kbeqzFoMHxpbNwf2VVlTYqOsFrbhRpdqC1pAdg=' 'sha256-cuQ92zuyuyjbvCLaBSWsazQjArgNs3p3hbWnLBr4RsQ=' 'sha256-73IL0Ty9SMZrT5b4eo1haMq/kuNmS05mTMiBlkUrTGY=' 'sha256-j5kw4rDkkF7+JVSXNstPvyPgw+IXjQ5idA6DT7P0oN0=' 'sha256-nW3JSmlx+jJcdvsxSTpjUWucXZjrf6X4kvJy0Y82feU=' 'sha256-nMY35tbLWqWpNSlCfdi/dyRY0g9gWeuN9KOW9JF1Wls=' 'sha256-wtr8HjxgPg+xZC+HiJ5x2p+b5Hf/C27IOqsuDvd8p84=' 'sha256-Q+p4Eo5o8lrh3AfU/wfIcuhKaap2F/rX9tcpP9g4O9U=' 'sha256-WmCCVAvlnCDh7Zpo+0yE6KNo6o758jpB2QnfpqaXjpU=' 'sha256-oqhFFkS6HwDHAte43rxaN8u9fyq1vBE5khTNLKrLZX8=' 'sha256-T2C+cKcpzHN9H7u57JIwGxrqKrbPFts65qeoWuMZ6aA=' 'sha256-2LcjwIi4DyX31TCpJYJmbX0XprSlYA5ZwOJfw4uogwc=' 'sha256-Ok42ILTkPYTbBYPUjTo+nV0/Rbgmbi+K6SrI0Q/zrhk=' 'sha256-wXkPUIwmXg2Vodrv4DfgqfIHRHA4MPzWtXfUny3s/YY=' 'sha256-Of7gcG+3C5hknUPlrCop3lPDxBZRh7qNRHPJe1IEsOM=' 'sha256-+c0L1d9okC3DX40G/y5izAb2jswTdLzeKFKqkw3fzEo='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is; frame-ancestors 'none'"
    Header append Vary "Accept-Encoding"
    <FilesMatch "\.(?:avif|css|gif|ico|jpe?g|js|mjs|png|svg|webp|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Brotli/GZIP Kompression
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

# Browser Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
